#version 450
// Fused per-environment RL rollout: ONE GPU thread = ONE environment.
//
// The env-specific dynamics/observation come from a SINGLE-SOURCE envdyn file (the
// exact same file the CPU learner compiles -- see env_dyn_compat.hpp), #included per
// task. Everything else here -- the actor MLP forward, sample_and_squash, the
// transition emit + reset -- is generic over the env's dims (ENV_OBS_DIM / ENV_ACT_DIM
// / ENV_STATE_DIM / ENV_EPISODE_STEPS, all defined by the envdyn file).
//
// Compiled once per task: -DENV_PENDULUM / -DENV_ACROBOT.
#extension GL_GOOGLE_include_directive : require

#define ENVDYN_FN
#define ENVDYN_OUT_ARR(T, name, N) out T name[N]
#if defined(ENV_ACROBOT)
#include "acrobot.envdyn"
#else
#include "pendulum.envdyn"
#endif

#define HID 64
#define OUT_DIM (2 * ENV_ACT_DIM)
const int TRANS = 2 * ENV_OBS_DIM + ENV_ACT_DIM + 2;// obs, action, reward, nextObs, trunc

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(push_constant, std430) uniform PC {
    uint n;
    uint stochastic;
    uint warmup;
} p;

layout(std430, binding = 0) readonly buffer Weights  { float w[]; };
layout(std430, binding = 1)          buffer State    { float st[]; };    // n*(ENV_STATE_DIM+1): vars..., epStep
layout(std430, binding = 2) readonly buffer Noise    { float nz[]; };
layout(std430, binding = 3) readonly buffer Initials { float ini[]; };   // n*ENV_STATE_DIM
layout(std430, binding = 4)          buffer Outp     { float o[]; };      // n*TRANS

// actor weight offsets for the MLP  ENV_OBS_DIM -> 64 -> 64 -> OUT_DIM
const int W1 = 0;
const int B1 = ENV_OBS_DIM * HID;
const int W2 = B1 + HID;
const int B2 = W2 + HID * HID;
const int W3 = B2 + HID;
const int B3 = W3 + OUT_DIM * HID;

void main() {
    uint e = gl_GlobalInvocationID.x;
    if (e >= p.n) return;

    uint base = e * uint(ENV_STATE_DIM + 1);
    float sbuf[ENV_STATE_DIM];
    for (int i = 0; i < ENV_STATE_DIM; ++i) sbuf[i] = st[base + uint(i)];
    int epStep = int(st[base + uint(ENV_STATE_DIM)]);

    EnvState s = envLoad(sbuf);
    EnvObs ob = envObserve(s);

    // actor: warmup emits uniform noise; otherwise MLP forward + sample_and_squash
    float action[ENV_ACT_DIM];
    if (p.warmup == 1u) {
        for (int a = 0; a < ENV_ACT_DIM; ++a) action[a] = nz[e * uint(ENV_ACT_DIM) + uint(a)];
    } else {
        float h1[HID], h2[HID];
        for (int oo = 0; oo < HID; ++oo) {
            float a = w[B1 + oo];
            for (int i = 0; i < ENV_OBS_DIM; ++i) a += w[W1 + oo * ENV_OBS_DIM + i] * ob.v[i];
            h1[oo] = a > 0.0 ? a : 0.0;
        }
        for (int oo = 0; oo < HID; ++oo) {
            float a = w[B2 + oo];
            for (int i = 0; i < HID; ++i) a += w[W2 + oo * HID + i] * h1[i];
            h2[oo] = a > 0.0 ? a : 0.0;
        }
        float outv[OUT_DIM];
        for (int oo = 0; oo < OUT_DIM; ++oo) {
            float a = w[B3 + oo];
            for (int i = 0; i < HID; ++i) a += w[W3 + oo * HID + i] * h2[i];
            outv[oo] = a;
        }
        for (int a = 0; a < ENV_ACT_DIM; ++a) {
            float mean = outv[a];
            float sd = exp(clamp(outv[ENV_ACT_DIM + a], -20.0, 2.0));
            float noise = (p.stochastic == 1u) ? nz[e * uint(ENV_ACT_DIM) + uint(a)] : 0.0;
            action[a] = tanh(mean + noise * sd);
        }
    }

    float reward = envReward(s, action);
    EnvState n = envStep(s, action);// s is now stepped
    EnvObs nob = envObserve(n);

    int nep = epStep + 1;
    float trunc = (nep >= ENV_EPISODE_STEPS) ? 1.0 : 0.0;

    uint b = e * uint(TRANS);
    int k = 0;
    for (int i = 0; i < ENV_OBS_DIM; ++i) o[b + uint(k++)] = ob.v[i];
    for (int i = 0; i < ENV_ACT_DIM; ++i) o[b + uint(k++)] = action[i];
    o[b + uint(k++)] = reward;
    for (int i = 0; i < ENV_OBS_DIM; ++i) o[b + uint(k++)] = nob.v[i];
    o[b + uint(k++)] = trunc;

    float outState[ENV_STATE_DIM];
    if (trunc > 0.5) {
        float ibuf[ENV_STATE_DIM];
        for (int i = 0; i < ENV_STATE_DIM; ++i) ibuf[i] = ini[e * uint(ENV_STATE_DIM) + uint(i)];
        envStore(envLoad(ibuf), outState);
        for (int i = 0; i < ENV_STATE_DIM; ++i) st[base + uint(i)] = outState[i];
        st[base + uint(ENV_STATE_DIM)] = 0.0;
    } else {
        envStore(n, outState);
        for (int i = 0; i < ENV_STATE_DIM; ++i) st[base + uint(i)] = outState[i];
        st[base + uint(ENV_STATE_DIM)] = float(nep);
    }
}
