#version 460
#extension GL_EXT_ray_tracing : require
#extension GL_EXT_scalar_block_layout : require
#extension GL_GOOGLE_include_directive : enable

// SER variant — compiled when CMake passes `-DSER=1`. Adds shader-execution
// reordering around the bounce trace: hitObjectTraceNV records the hit data
// without invoking the closest_hit, reorderThreadNV groups warp threads by
// hit material, hitObjectExecuteShaderNV then dispatches the closest_hit
// with coherent neighbours. NVIDIA Ada/Ampere HW-accelerates the reorder;
// older NVIDIA falls through the driver SW path. The non-SER SPV is loaded
// for AMD / Intel / older NVIDIA (kRaygenRgenSpv vs kRaygenRgenSerSpv pick
// happens at RT pipeline creation in VulkanRenderer.cpp).
#ifdef SER
#extension GL_NV_shader_invocation_reorder : require
#endif

#include "vulkan_shared.h"

// Phase 4a: derive ray origin / direction from a real threepp Camera. The
// host uploads camera.matrixWorld (viewInverse) and camera.projectionMatrixInverse
// (projInverse). Ray construction follows the standard NV/Khronos pattern:
// eye in view-space is (0,0,0); the pixel target in view-space comes from
// projInverse * (ndc, 1, 1); both transform to world-space via viewInverse.
//
// Pixel (0,0) is top-left of the swapchain image, while NDC y = +1 is the
// top of the projection frustum, so we flip y after the [-1,1] remap.
//
// Phase 8: progressive accumulation. Each frame we jitter the primary ray
// inside its pixel (blue-noise tile) and average the result into a persistent
// rgba32f accumulator (binding 7). The host resets `pc.sampleIndex` to 0
// whenever the camera or env changes. denoise.comp tonemaps + sRGB-encodes
// the accumulator to the swapchain image (binding 1) for display.
//
// Phase 9: iterative path tracing. We loop up to kMaxBounces times,
// tracing a primary then sampled indirect bounces. closest_hit fills the
// payload with direct lighting at the hit + a sampled bounce direction
// + a throughput multiplier; raygen accumulates
// `throughput * (payload.radianceDiff + payload.radianceSpec)`
// and traces the next ray. miss writes env color and terminates the path.
// Recursion lives in this loop, not in chained traceRayEXT calls — the
// pipeline's maxRecursionDepth only needs to cover the in-shader shadow
// rays from closest_hit.

struct Payload {
    // Diffuse + specular split — each channel reproject/accumulate/filter
    // independently. Diffuse content (Lambertian, ambient, emissive,
    // caustics) is view-INdependent: surface-anchored reproject is exact,
    // long history is desirable. Specular content (Cook-Torrance lit, env
    // BRDF spec) is view-DEPENDENT: surface-anchored reproject mixes
    // prev-view lobe with new-view lobe → trails on camera motion. Spec
    // channel uses FC=1 (no history) until virtual reproject lands.
    vec3 radianceDiff; // diffuse-channel contribution at this hit
    vec3 radianceSpec; // specular-channel contribution at this hit
    vec3 brdfWeight;   // throughput multiplier for the next bounce (BRDF·cos/pdf)
    vec3 nextOrigin;   // world-space origin for the next bounce ray
    vec3 nextDir;      // world-space direction for the next bounce ray
    uint flags;        // bit 0: terminate path (env hit or no scatter)
    uint seed;         // PCG state threaded through bounces
    vec3 hitWorldPos;  // world-space hit point (for primary-hit reprojection)
    uint hitInstanceId;// gl_InstanceCustomIndexEXT + 1; 0 == miss/sky
    // Per-vertex motion-vector reproject support: chit interpolates the
    // previous-frame deformed positions of the hit triangle via
    // gdesc.prevVertexAddress, transforms with gl_ObjectToWorldEXT, and
    // stores the result here. For static (non-deforming) geometry the
    // prevVertex buffer is the same as vertex so this ends up equal to
    // hitWorldPos. raygen uses motionMat * prevWorldPos for the reproject
    // — correctly handles skinned-mesh deformation that motionMat alone
    // (= identity for skinned) cannot capture.
    vec3 prevWorldPos;
    float hitRoughness;// post-clamp surface roughness; primary-hit FC cap input
    uint inFlags;      // raygen→closest_hit: bit 0 = scatter>0 (suppress emission;
                       // NEE on the prev shade already covered emissive light at this hit)
    float hitMetalness;   // post-clamp metalness; raygen uses for adaptive bounce cap
    float hitTransmission;// post-clamp transmission; raygen uses for adaptive bounce cap
    float bsdfPdf;        // chit→miss: pdf of the BSDF-sampled bounce direction;
                          //  miss uses for proper MIS env weight when env CDF is on
    float currentIor;     // medium-stack tracking: the IOR of the medium the ray is currently
                          //  travelling through (1.0 = air at primary). closest_hit's
                          //  transmission lobe uses this to determine eta (currentIor/targetIor)
                          //  and updates it on a refraction event. Fixes camera-inside-closed-glass
                          //  (e.g. windshield from cabin) where geometric isFront alone misclassifies
                          //  back-face hits as "exiting glass" when the ray was actually in air.
    float hitSpecFrac;    // chit→raygen: estimated fraction of this primary hit's
                          //  outgoing radiance that comes from the view-DEPENDENT
                          //  spec lobe (vs view-INDEPENDENT diffuse). Range [0,1].
                          //  Used as the actual decay signal for the motion-time
                          //  FC override — replaces the old `1-smoothstep(roughness)`
                          //  heuristic which missed dark surfaces where diff is
                          //  dim and Fresnel spec dominates (wet asphalt, dark
                          //  paint, cones at low NdotV). Computed at primary
                          //  only; 0 on bounces / pass-throughs / sky.
    vec4 primaryAlbedo;   // chit→raygen: primary-surface albedo for atrous
                          //  demodulation. .rgb = clamped albedo; .a = demod-valid
                          //  flag (1 = enable demod, 0 = fall back to radiance-
                          //  space filter). Raygen temporally accumulates this
                          //  alongside radiance with the SAME FC blend + reproject
                          //  gates, so the demod division stays mathematically
                          //  consistent under motion (snapshot albedo / FC-blended
                          //  radiance previously produced ghost trails when the
                          //  two channels had inconsistent temporal characteristics).
    vec3 hitNormal;       // world-space shading normal at this hit
                          //  (post normal-map, post double-side flip). Zero on
                          //  miss / sky / pass-through. Used by chit's ReSTIR GI
                          //  to populate the reservoir candidate (xs, ns, Lo) —
                          //  ns is read from the GI sub-ray's payload.hitNormal.
                          //  Doesn't replace prevWorldPos / hitWorldPos — those
                          //  drive reproject, this drives the GI target function.
};

// ── Specialization constants ──────────────────────────────────────────────
// Pipeline-time feature gates. Compiled into the SPIR-V at vkCreate...; the
// optimizer DCEs the unreachable branch entirely. Host picks the right
// variant (see rtVariants_) per frame based on which features are enabled —
// no runtime branch on motionFlags, no register pressure for the dead path.
// constant_id values are stable: don't renumber, or stored caches go stale.
// Raygen's namespace is independent of chit's; both can start at 0.
layout(constant_id = 0) const bool kHybridEnabled = false;
// Scene-feature bitmask — set at first-frame pipeline build by the host
// (currentSceneFeatures() in VulkanRenderer.cpp). Bit assignments match
// chit's kSceneFeatures one-for-one:
//   1 = kSceneFeatHasGlass
//   2 = kSceneFeatHasClearcoat
//   4 = kSceneFeatHasIridescence
//   8 = kSceneFeatHasSheen
// Used by the bounce-0-on-raster gbuf-shade path for the same DCE that chit
// gets — caustic gather / clearcoat lobe / iridescence Fresnel mix / sheen
// NEE terms vanish from the raygen SPV when the scene doesn't use them.
layout(constant_id = 1) const uint kSceneFeatures = 0u;
const uint kSceneFeatHasGlass       = 1u;
const uint kSceneFeatHasClearcoat   = 2u;
const uint kSceneFeatHasIridescence = 4u;
const uint kSceneFeatHasSheen       = 8u;
// (constant_id = 2 was the bounce-0-on-raster gate — removed because the
// gbuf-shade primary path proved slower than the traced primary on hybrid +
// SER hardware; warp divergence at silhouette/glass/water boundaries plus
// the lost SER coherence at primary cost more than the BVH-traversal save.
// Reserved here to avoid renumbering if a different raygen spec constant
// lands in the future.)

layout(set = 0, binding = 0) uniform accelerationStructureEXT topAS;
// Binding 1 (outImage, rgba8) is written by denoise.comp after the RT pass —
// raygen no longer touches it. The descriptor remains in set 0 with a
// COMPUTE_BIT stage flag so the same descriptor set drives both pipelines.
layout(set = 0, binding = 2) uniform CameraUbo {
    mat4 viewInverse;
    mat4 projInverse;
    // .xy = clip-space sub-pixel jitter offset matching the raster G-buffer
    // pass's Halton(2,3) sequence. raygen applies it to the primary NDC in
    // hybrid mode so V varies per frame (TAA integrates correctly across
    // the Halton period). Zero in non-hybrid mode — the chit's per-frame
    // Halton on the primary still produces the same effect there.
    // .zw = previous frame's clip-space jitter. The hybrid reproject below
    // uses (zw - xy) to shift bilinear taps so they hit the same sub-pixel
    // location in prevAccumImage that the prev raster jitter wrote to —
    // without this, moving objects wobble (per-frame jitter delta cycles
    // through Halton 2/3 values and pure PT averages it out via spp, but
    // hybrid rasterizes once per frame so the shake shows through).
    vec4 jitter;
} cam;
layout(set = 0, binding = 7, rgba32f) uniform image2D accumImage;
// Continuous-motion accumulation (Phase: motion). The previous frame's
// view-projection matrix lets us reproject this frame's primary hit world
// position back to the prior frame's pixel; the motion matrix per-instance
// converts current-frame world space → previous-frame world space when the
// hit object also moved. The gbuf images carry the primary world hit + a
// mesh ID guard, ping-pong each frame in flight: binding 11/13 read the
// previous frame's writes; binding 7/12 write this frame's. Per-pixel
// frameCount is stored directly in accumImage.w as a small float integer.
layout(set = 0, binding = 9) uniform PrevCameraUbo {
    vec4 prevCamPosX;  // .xyz = world position,  .w = projScaleX = 1/(aspect*tanHalfFovY)
    vec4 prevCamFwdY;  // .xyz = forward direction, .w = projScaleY = 1/tanHalfFovY
    vec4 prevCamRgt;   // .xyz = right direction,   .w = unused
    vec4 prevCamUp;    // .xyz = up direction,       .w = unused
} pcam;
layout(set = 0, binding = 10, std430) readonly buffer MotionMatBuf {
    mat4 motionMat[];
};
layout(set = 0, binding = 11, rgba32f) uniform readonly image2D prevAccumImage;
layout(set = 0, binding = 12, rgba32f) uniform writeonly image2D gbufImage;
layout(set = 0, binding = 13, rgba32f) uniform readonly image2D prevGbufImage;
// Temporal moments ping-pong (R32F). Stores per-pixel mean(luminance²)
// accumulated alongside accumImage with the same FC weight. Atrous reads
// this to compute variance = max(M2 − luminance(mean)², 0) and derive a
// per-pixel σ_lum for its edge stop — instead of a constant 1.5 that
// over-blurs noisy pixels and over-preserves detail in cleanly-converged
// regions. Population-variance form (not divided by N) is what SVGF's
// luminance edge stop wants.
layout(set = 0, binding = 33, r32f) uniform writeonly image2D momentsImage;
layout(set = 0, binding = 34, r32f) uniform readonly  image2D prevMomentsImage;
// Primary-surface albedo accumulator (ping-pong, rgba8). Raygen FC-blends
// the prev-frame slot (binding 36) at the reprojected pixel with the
// chit-provided current-frame snapshot (payload.primaryAlbedo), writes the
// blended result to the current-frame slot (binding 35). atrous reads
// binding 35. The temporal blend keeps demod's two channels (radiance and
// albedo) in lockstep so divisions stay mathematically consistent under
// motion — fixes the position-fixed ghost trails the snapshot albedo
// previously produced when accumImage carried multi-frame history but
// the albedo channel was just-this-frame data.
layout(set = 0, binding = 35, rgba8) uniform writeonly image2D primaryAlbedoImage;
layout(set = 0, binding = 36, rgba8) uniform readonly  image2D prevPrimaryAlbedoImage;
// Snapshot of THIS frame's chit-provided primaryAlbedo (no temporal blend).
// Atrous reads at center pixel and uses for re-modulation, so texture
// detail stays per-frame crisp while the temporal-smoothed primaryAlbedoImage
// drives the demod division (smoothed albedo / smoothed radiance =
// stable lighting, snapshot * lighting = crisp textured output).
layout(set = 0, binding = 37, rgba8) uniform writeonly image2D primaryAlbedoSnapshotImage;

// Hybrid raster G-buffer attachments. Always bound (allocated at startup);
// raygen samples them only when `kHybridEnabled` is true. That branch is a
// specialization constant so the dead code is DCEd in the non-hybrid pipeline
// variant — descriptor set still lists these slots, but the SPV never reads
// from them in that variant.
// Hybrid uses the motion vector for reproject and the ids texture for the
// sky early-out; normal/depth/uv are bound but currently unused (they were
// wired for the abandoned in-raygen skip-primary path). Sampler is
// nearest-filter so silhouette pixels don't bleed.
layout(set = 0, binding = 22) uniform sampler2D  gbufNormalTex;// world normal in n*0.5+0.5 encoding
layout(set = 0, binding = 23) uniform sampler2D  gbufMotionTex;// rg = (prevNDC - currNDC) in GL convention
layout(set = 0, binding = 24) uniform sampler2D  gbufDepthTex; // .r = depth (Vulkan NDC z, [0,1])
layout(set = 0, binding = 25) uniform usampler2D gbufIdsTex;   // .x = instanceCustomIndex+1; 0 == sky/miss
layout(set = 0, binding = 26) uniform sampler2D  gbufUvTex;    // .rg = material UV
layout(set = 0, binding = 27) uniform sampler2D  blueNoiseTex; // 64×64 R8 void-and-cluster tile, sampled at (px+frame_offset, py+frame_offset) % 64

// Material + bindless texture descriptors. mats[] is read by the hybrid
// reproject bilinear-tap material-acceptance gate and by primary-hit
// material asset capture; albedoMaps[] is sampled for primary albedo.
// C++ side adds VK_SHADER_STAGE_RAYGEN_BIT_KHR to bindings 4 and 8.
layout(set = 0, binding = 4, scalar) readonly buffer MatDescBuf {
    MaterialDesc mats[];
};
layout(set = 0, binding = 8) uniform sampler2D albedoMaps[kMaxMaterialTextures];
// Env luminance CDF — same buffers chit reads (rtDsLayout bindings 18/19).
layout(set = 0, binding = 18) uniform sampler2D envCdfTex; // conditional CDF
layout(set = 0, binding = 19) uniform sampler2D envMargTex;// marginal CDF

// PI / TWO_PI live in shade_common.glsl (included below, after the bindings).

// ─── Fog (homogeneous participating media) ─────────────────────────────────
// Bindings 5/6/14/17 are also bound to closest_hit; they're re-staged into
// RAYGEN at descriptor-layout time so the in-loop volumetric integrator
// (volumeNeeSingle at each scatter event) can NEE to all scene light sources
// without round-tripping through closest_hit.
//
// Light / emissive structs duplicated from closest_hit.rchit (matching the
// Payload-struct duplication pattern). Field layout / std140 alignment must
// stay byte-identical with the host GpuLightsUbo / GpuFogUbo / EmTri.
struct DirLight {
    vec3 direction;
    vec3 color;
};
struct PointLight {
    vec3  position;
    float range;
    vec3  color;
    float decay;
};
struct SpotLight {
    vec3  position;
    float range;
    vec3  color;
    float decay;
    vec3  direction;
    float cosAngleOuter;
    float cosAngleInner;
};
struct RectLight {
    vec3 position;
    vec3 halfU;
    vec3 halfV;
    vec3 normal;
    vec3 color;
};
layout(set = 0, binding = 5, scalar) uniform LightsUbo {
    vec3       ambient;
    uint       dirCount;
    DirLight   dirLights[8];
    uint       pointCount;
    uint       spotCount;
    uint       rectCount;
    PointLight pointLights[8];
    SpotLight  spotLights[8];
    RectLight  rectLights[4];
} lights;
layout(set = 0, binding = 6) uniform sampler2D envTex;

struct EmTri {
    vec4 v0;        // xyz = pos, w = area
    vec4 v1;        // xyz = pos, w = cumPower (running CDF)
    vec4 v2;        // xyz = pos, w = power (lum * area)
    vec4 emission;  // xyz = emissive*intensity, w = unused
};
layout(set = 0, binding = 14, scalar) readonly buffer EmissiveTriBuf {
    EmTri emissiveTris[];
};

// Photon-map storage (written by photon_emit.rgen, gathered by the hybrid
// bounce-0-on-raster path via gatherCaustics() — same bindings the chit reads).
layout(set = 0, binding = 15, std430) readonly buffer PhotonCountBuf { uint photonCounts[]; };
layout(set = 0, binding = 16, scalar) readonly buffer PhotonDataBuf  { vec3 photonData[];   };

// Per-instance moved-bitmask: bit i of meshMovedBits[i>>5] is set when TLAS
// instance i had any kind of change this frame (xfm, material, bones, displ).
// Sized at scene rebuild to cover every visible instance.
layout(set = 0, binding = 21, std430) readonly buffer MeshMovedBitsBuf {
    uint meshMovedBits[];
};

layout(set = 0, binding = 17) uniform FogUbo {
    vec3  sigmaT;
    float enabled;
    vec3  color;
    float anisotropy;
    float waterSurfaceY;
} fog;

// fogEnabled() / fogTransmittance() live in shade_common.glsl (included
// below, after main()'s prelude — but only AFTER the binding declarations
// they reference). The forward-decl block in shade_common.glsl handles
// the call sites in this file that come before #include.

// Effective participating-medium length along a ray segment.
//  * Unbounded medium (waterSurfaceY ≥ 1e20): full segment, except env miss
//    (`isEnvMiss == true`) is capped at atmospheric scale 1e4 so thin fog
//    still lets distant sky through.
//  * Water column (waterSurfaceY < 1e20): if the ray starts below the surface
//    and is heading up, the medium ends at the exit point; otherwise the
//    same global cap applies.
// Used by the in-loop volumetric integrator to confine scatter sampling and
// Beer-Lambert to the actual medium volume.
float fogSegmentLength(vec3 rayOrigin, vec3 rayDir, float maxDist, bool isEnvMiss) {
    float len = isEnvMiss ? min(maxDist, 1e4) : maxDist;
    if (fog.waterSurfaceY < 1e20 && rayOrigin.y < fog.waterSurfaceY
            && rayDir.y > 1e-4) {
        len = min(len, (fog.waterSurfaceY - rayOrigin.y) / rayDir.y);
    }
    return len;
}
// Henyey-Greenstein phase. g∈(-1,1): 0 isotropic, >0 forward (god rays), <0 back.
float phaseHG(float cosTh, float g) {
    const float g2 = g * g;
    const float denom = 1.0 + g2 - 2.0 * g * cosTh;
    return (1.0 - g2) / (4.0 * 3.14159265358979 * max(denom * sqrt(max(denom, 1e-6)), 1e-6));
}

// Sample a scattered direction from the Henyey-Greenstein phase function
// centered on the incoming-ray direction `wi`. PBRT v4 §11.3 inversion:
//   cosθ = -(1+g² - ((1-g²)/(1-g+2gξ))²) / (2g)   for g ≠ 0
//   cosθ = 1 − 2ξ                                 for g ≈ 0 (isotropic)
// Returned world-space direction wo satisfies dot(wi, wo) = cosθ, matching
// the phaseHG convention. Used by the in-loop volumetric integrator at scatter
// events to continue the path; the throughput contribution from "sample
// direction with the phase function" is 1 (phase / phasePdf cancels exactly).
vec3 sampleHG(vec3 wi, float g, vec2 u) {
    float cosTheta;
    if (abs(g) < 1e-3) {
        cosTheta = 1.0 - 2.0 * u.x;
    } else {
        const float sqrTerm = (1.0 - g * g) / (1.0 - g + 2.0 * g * u.x);
        cosTheta = -(1.0 + g * g - sqrTerm * sqrTerm) / (2.0 * g);
        cosTheta = clamp(cosTheta, -1.0, 1.0);
    }
    const float sinTheta = sqrt(max(0.0, 1.0 - cosTheta * cosTheta));
    const float phi      = 6.28318530717958 * u.y;
    // Orthonormal basis around wi (z-axis = wi). Avoid degenerate cross product
    // when wi is near ±x by picking a fallback axis.
    const vec3 a = (abs(wi.x) > 0.99) ? vec3(0.0, 1.0, 0.0) : vec3(1.0, 0.0, 0.0);
    const vec3 t = normalize(cross(a, wi));
    const vec3 b = cross(wi, t);
    return sinTheta * (cos(phi) * t + sin(phi) * b) + cosTheta * wi;
}

// Equirect env sampler — duplicates miss.rmiss / closest_hit.rchit logic
// (GL/three.js convention: u = 0.5 + atan2(z,x)/2π, v = 0.5 + asin(y)/π).
vec3 sampleEquirectFog(vec3 dir) {
    const float U = 0.5 + atan(dir.z, dir.x) / 6.28318530717958;
    const float V = 0.5 + asin(clamp(dir.y, -1.0, 1.0)) / 3.14159265358979;
    return texture(envTex, vec2(U, V)).rgb;
}

// .x sampleIndex, .y envMipCount (closest_hit), .z toneMapping enum
// (None=0, Linear=1, Reinhard=2, Cineon=3, ACESFilmic=4, Custom=5),
// .w toneMappingExposure as float-bits, .v[1] motionFlags
// (bit 0 = any motion this frame, bit 1 = camera viewProj changed,
//  bit 2 = scene has any glass material — gates caustic gather).
// Per-instance moved bits live in the binding 21 SSBO; isMeshMoved()
// queries by primaryInstanceId-1 so FC-halving is per-pixel rather than
// scene-wide. When motionFlags bit 0 is unset raygen takes the self-tap
// accumulation path and skips the reproject math entirely — float-precision
// pixel-snap drift on a static scene was visibly wobbly otherwise.
layout(push_constant) uniform Pc {
    uint sampleIndex;
    uint envMipCount;
    uint toneMapping;
    uint exposureBits;
    uint motionFlags;
    uint emissiveCount;       // # of emissive triangles (closest_hit reads this)
    float emissiveTotalPower; // total power CDF max (closest_hit reads this)
    uint samplesPerPixel;     // # of jittered primary rays per frame (>=1)
    uint envCdfWidth;         // env CDF dims (closest_hit + miss; raygen ignores)
    uint envCdfHeight;
    float envCdfTotalSum;     // env importance pdf normaliser; 0 disables CDF
    float fireflyClamp;       // per-NEE luminance cap (closest_hit reads); 1e30 disables
    float oceanFineTileSize;  // fine-cascade tile size (closest_hit reads); 0 disables
    uint edgeMsaaExtra;       // # of EXTRA primary samples at detected silhouettes
                              // (0 = disable silhouette MSAA, N = (N+1)× MSAA at edges)
    float _padFoam;           // closest_hit-only (world-space foam tile size); reserved
                              // here so the slot offsets stay aligned across stages.
    uint maxBounces;          // max real scatter events per path (raygen reads); cap for
                              // diffuse/glossy is further reduced in main() via kMaxBounces.
} pc;

bool isMeshMoved(uint idx) {
    const uint w = idx >> 5u;
    if (w >= meshMovedBits.length()) return false;
    return (meshMovedBits[w] & (1u << (idx & 31u))) != 0u;
}

layout(location = 0) rayPayloadEXT Payload payload;
// Second payload slot for fog inscatter shadow rays (NEE from scatter points
// in the volume). Mirrors closest_hit.rchit's location=1 declaration; the SBT
// shadow miss sets this to 1.0, shadow_anyhit multiplies it down through glass.
layout(location = 1) rayPayloadEXT float shadowVisibility;

// Shared BSDF / NEE / sampling helpers — same source the chit uses.
// References envTex, fog, envCdf/Marg, photonCounts/Data, lights,
// emissiveTris, topAS, shadowVisibility, pc — all declared above.
// Provides: PI, TWO_PI, pcgNext, urand, lum3, BSDF math, env CDF,
// VNDF sampling, sampleBsdf, envNeeOpaque, analyticNeeOpaque, etc.
#include "shade_common.glsl"

// kMaxBounces is set per-frame from `pc.maxBounces` at the top of main() — the
// host's setMaxBounces(int) API drives it. Default is 4 (the previous compile-
// time value). Diffuse/glossy adaptively cap further at 3/4 below, so the
// runtime value only directly affects the metal/mirror/glass branch's deeper
// indirect bounces — bump it up if you start seeing under-lit metal cavities
// or missing glass→glass→sky paths.
const int kMaxSteps   = 24;// hard cap including glass traversal (each glass layer = 2 steps)

// Halton low-discrepancy sequence — base 2 / base 3 give the standard
// (x, y) sub-pixel jitter pattern used by virtually every progressive PT.
float halton(uint i, uint b) {
    float f = 1.0;
    float r = 0.0;
    while (i > 0u) {
        f /= float(b);
        r += f * float(i % b);
        i /= b;
    }
    return r;
}

// Initial PCG seed for this pixel + sample. Mixed with a Weyl constant so
// neighbouring pixels and successive samples decorrelate quickly.
uint seedFor(uvec2 px, uint s) {
    uint h = px.x * 1973u ^ px.y * 9277u ^ s * 26699u;
    h ^= h >> 16;
    h *= 0x85EBCA6Bu;
    h ^= h >> 13;
    return h | 1u;// avoid the absorbing all-zero state
}

// Real blue-noise tile lookup. The 64×64 tile is generated host-side via
// void-and-cluster (Ulichney 1993) at startup and bound at slot 27.
// Adjacent pixels have correlated values (silhouette stability), globally
// decorrelated (no coherent shake), low-frequency content suppressed
// (denoise + TAA absorb the high-frequency variance).
//
// Per-frame temporal animation: offset the lookup by frame-dependent
// integer steps so each pixel reads a different tile cell each frame,
// cycling through the full sequence over ~64 frames → temporal AA via
// accumulator integration. The two `salt` values produce independent x/y
// jitter samples by stepping the lookup along different irrational rates.
float blueNoise(uvec2 px, uint frame, uint salt) {
    const ivec2 step = ivec2(47, 17) * int(salt + 1u);
    const ivec2 cell = ivec2(px) + step * int(frame);
    const vec2  uv   = (vec2(cell & 63) + 0.5) / 64.0;
    return texture(blueNoiseTex, uv).r;
}

// pcgNext / urand live in shade_common.glsl (same source the chit uses).

// Swapchain is B8G8R8A8_UNORM but presented under SRGB_NONLINEAR — display
// expects sRGB-encoded values. closest_hit returns linear HDR radiance, so
// we encode here.
vec3 linearToSRGB(vec3 x) {
    const vec3 cutoff = vec3(lessThan(x, vec3(0.0031308)));
    const vec3 lower  = 12.92 * x;
    const vec3 higher = 1.055 * pow(max(x, vec3(0.0)), vec3(1.0 / 2.4)) - 0.055;
    return mix(higher, lower, cutoff);
}

// Tone mapping operators copied from threepp's GL shader chunks
// (tonemapping_pars_fragment) so the Vulkan PT honors Renderer.toneMapping
// the same way the raster path does. Selected at runtime by pc.toneMapping;
// the linear HDR mean from accumImage is fed in, the LDR result then runs
// through the sRGB encode below.
vec3 reinhard(vec3 c) { return clamp(c / (vec3(1.0) + c), 0.0, 1.0); }
vec3 cineon(vec3 c) {
    c = max(vec3(0.0), c - 0.004);
    return pow((c * (6.2 * c + 0.5)) / (c * (6.2 * c + 1.7) + 0.06), vec3(2.2));
}
vec3 acesFilmic(vec3 c) {
    const mat3 inMat = mat3(
            vec3(0.59719, 0.07600, 0.02840),
            vec3(0.35458, 0.90834, 0.13383),
            vec3(0.04823, 0.01566, 0.83777));
    const mat3 outMat = mat3(
            vec3( 1.60475, -0.10208, -0.00327),
            vec3(-0.53108,  1.10813, -0.07276),
            vec3(-0.07367, -0.00605,  1.07602));
    c = inMat * c;
    const vec3 a = c * (c + 0.0245786) - 0.000090537;
    const vec3 b = c * (0.983729 * c + 0.4329510) + 0.238081;
    return clamp(outMat * (a / b), 0.0, 1.0);
}
vec3 toneMap(vec3 c, uint mode, float exposure) {
    if (mode == 1u) return c * exposure;                  // Linear
    if (mode == 2u) return reinhard(c * exposure);        // Reinhard
    if (mode == 3u) return cineon(c * exposure);          // OptimizedCineon
    if (mode == 4u) return acesFilmic(c * (exposure / 0.6));// ACESFilmic
    return c;// None / Custom — pass-through
}

// ─── Fog inscatter helpers ────────────────────────────────────────────────
// Shadow ray for fog NEE. Mirrors closest_hit.rchit's traceRayEXT pattern:
// sbtRecordOffset=1 selects the shadow hit group (shadow_anyhit), missIndex=1
// selects shadow_miss. NoOpaqueEXT routes glass/cutout through any-hit so
// transmissive geometry attenuates the visibility through `shadowVisibility`.
// Volumetric Beer-Lambert is applied here when the ray endpoint is finite
// (maxDist < 1e20). Infinite sentinels (sun / env) bypass fog attenuation.
vec3 traceFogShadowRay(vec3 origin, vec3 dir, float maxDist) {
    shadowVisibility = 1.0;
    traceRayEXT(topAS,
                gl_RayFlagsTerminateOnFirstHitEXT |
                gl_RayFlagsSkipClosestHitShaderEXT |
                gl_RayFlagsNoOpaqueEXT,
                0xff, 1, 0, 1,
                origin, 1e-4, dir, maxDist, 1);
    vec3 atten = vec3(shadowVisibility);
    if (fogEnabled() && maxDist < 1e20) atten *= fogTransmittance(maxDist);
    return atten;
}

// Sample a point on the emissive-tri CDF, return position / normal / area /
// power. Direct port of closest_hit.rchit's emissive-NEE block (binary search
// on cumPower, sqrt-barycentric uniform-by-area sample). Two-sided emitter
// convention matches closest_hit (cosLight uses |dot|).
struct EmissiveSample {
    vec3 point;
    vec3 normal;
    float area;
    float power;
    vec3 emission;
};
EmissiveSample sampleEmissiveTriCdfFog(inout uint seed) {
    EmissiveSample es;
    es.area = 0.0;
    es.power = 0.0;
    es.emission = vec3(0.0);
    if (pc.emissiveCount == 0u || pc.emissiveTotalPower <= 0.0) return es;
    const float xi = urand(seed) * pc.emissiveTotalPower;
    uint lo = 0u;
    uint hi = pc.emissiveCount - 1u;
    // Tightest binary-search bound: ceil(log2(emissiveCount)). Old 32-cap
    // supported up to 2^32 entries — far beyond any real scene. See the
    // matching block in closest_hit.rchit for the same fix.
    const int emIters = findMSB(max(pc.emissiveCount - 1u, 1u)) + 1;
    for (int s = 0; s < emIters; ++s) {
        if (lo >= hi) break;
        const uint mid = (lo + hi) >> 1u;
        if (emissiveTris[mid].v1.w < xi) lo = mid + 1u;
        else                              hi = mid;
    }
    const EmTri t = emissiveTris[lo];
    const float r1 = urand(seed);
    const float r2 = urand(seed);
    const float su1 = sqrt(r1);
    const float bA = 1.0 - su1;
    const float bB = su1 * (1.0 - r2);
    const float bC = su1 * r2;
    es.point  = bA * t.v0.xyz + bB * t.v1.xyz + bC * t.v2.xyz;
    es.normal = normalize(cross(t.v1.xyz - t.v0.xyz, t.v2.xyz - t.v0.xyz));
    es.area   = t.v0.w;
    es.power  = t.v2.w;
    es.emission = t.emission.rgb;
    return es;
}

// Per-contribution firefly clamp for analytical-light inscatter. Stratified
// scatter points that land near a point/spot light hit the 1/d² singularity
// — even with the `pow(dist, decay)` floor, attenuation can spike to 100×.
// Clamping per-sample luminance (matches closest_hit's emissive-NEE cap at
// line ~1179) trades a small bias near sources for vastly fewer fireflies.
// Cap chosen at 8.0: lower than the surface-NEE cap (20) because volumetric
// samples are integrated over a much shorter "exposure" — N=4 stratified
// taps per pixel vs the dense bounce coverage on surfaces.
void addInscatter(inout vec3 sum, vec3 c) {
    const float lum = dot(c, vec3(0.2126, 0.7152, 0.0722));
    if (lum > 8.0) c *= 8.0 / lum;
    sum += c;
}

// Single-point in-medium NEE estimator. At a scatter event at world-position
// `x` (the path is in the medium, came in along direction `wi`), sample one
// shadow ray per light source and return the sum of HG-phase-weighted direct
// radiance. Per-light firefly cap via addInscatter() suppresses 1/d² and
// near-grazing-emitter spikes. Used by both:
//   * the in-loop unbiased volumetric integrator (one call per scatter event)
//   * volumeInscatter() (N stratified calls along a single segment, for the
//     legacy primary-only single-scatter overlay)
// Returns radiance with units already in [Le · sr⁻¹], no σ_s factor — the
// caller is responsible for multiplying by the medium albedo (σ_s/σ_t) and
// any throughput.
vec3 volumeNeeSingle(vec3 x, vec3 wi, float g, inout uint seed) {
    vec3 nee = vec3(0.0);

    // (a) Emissive-tri NEE
    if (pc.emissiveCount > 0u && pc.emissiveTotalPower > 0.0) {
        const EmissiveSample es = sampleEmissiveTriCdfFog(seed);
        if (es.area > 1e-20 && es.power > 0.0) {
            vec3 toL = es.point - x;
            const float dist = max(length(toL), 1e-4);
            toL /= dist;
            const float cosLight = abs(dot(-toL, es.normal));
            if (cosLight > 1e-4) {
                const vec3 atten = traceFogShadowRay(x, toL, dist - 1e-2);
                const float pickPdf  = es.power / pc.emissiveTotalPower;
                const float pdfArea  = pickPdf / es.area;
                const float pdfOmega = pdfArea * dist * dist / cosLight;
                if (pdfOmega > 1e-10) {
                    const float ph = phaseHG(dot(wi, toL), g);
                    // Per-tap firefly cap — emTri NEE pdfOmega gets small for
                    // grazing emitter angles, amplifying the contribution.
                    addInscatter(nee, ph * es.emission * atten / pdfOmega);
                }
            }
        }
    }

    // (b) Analytical lights — dir / point / spot / rect
    for (uint li = 0u; li < lights.dirCount; ++li) {
        const vec3 L = normalize(lights.dirLights[li].direction);
        const vec3 atten = traceFogShadowRay(x, L, 1e30);
        const float ph = phaseHG(dot(wi, L), g);
        addInscatter(nee, ph * lights.dirLights[li].color * atten);
    }
    // PointLights — physical falloff matches closest_hit. Stratified taps that
    // land near the source spike via 1/d²; addInscatter caps per-tap luminance.
    // Floor of pow() at 0.1 (vs closest_hit's 0.01) — volumetric samples are
    // sparse so the singularity is much more visible.
    for (uint li = 0u; li < lights.pointCount; ++li) {
        vec3 toL = lights.pointLights[li].position - x;
        const float dist = length(toL);
        if (dist < 1e-4) continue;
        toL /= dist;
        const float decay = lights.pointLights[li].decay;
        float att = 1.0 / max(pow(dist, decay), 0.1);
        const float range = lights.pointLights[li].range;
        if (range > 0.0) {
            const float t  = dist / range;
            const float t4 = t * t * t * t;
            const float w  = max(1.0 - t4, 0.0);
            att *= w * w;
        }
        const vec3 atten = traceFogShadowRay(x, toL, dist - 1e-2);
        const float ph = phaseHG(dot(wi, toL), g);
        addInscatter(nee, ph * lights.pointLights[li].color * att * atten);
    }
    for (uint li = 0u; li < lights.spotCount; ++li) {
        vec3 toL = lights.spotLights[li].position - x;
        const float dist = length(toL);
        if (dist < 1e-4) continue;
        toL /= dist;
        const float spotCos = dot(-toL, lights.spotLights[li].direction);
        const float spotAtten = smoothstep(lights.spotLights[li].cosAngleOuter,
                                           lights.spotLights[li].cosAngleInner,
                                           spotCos);
        if (spotAtten <= 0.0) continue;
        const float decay = lights.spotLights[li].decay;
        float att = 1.0 / max(pow(dist, decay), 0.1);
        const float range = lights.spotLights[li].range;
        if (range > 0.0) {
            const float t  = dist / range;
            const float t4 = t * t * t * t;
            const float w  = max(1.0 - t4, 0.0);
            att *= w * w;
        }
        att *= spotAtten;
        const vec3 atten = traceFogShadowRay(x, toL, dist - 1e-2);
        const float ph = phaseHG(dot(wi, toL), g);
        addInscatter(nee, ph * lights.spotLights[li].color * att * atten);
    }
    for (uint li = 0u; li < lights.rectCount; ++li) {
        const float ru = urand(seed) * 2.0 - 1.0;
        const float rv = urand(seed) * 2.0 - 1.0;
        const vec3 samplePos = lights.rectLights[li].position
                             + ru * lights.rectLights[li].halfU
                             + rv * lights.rectLights[li].halfV;
        vec3 toL = samplePos - x;
        const float dist = length(toL);
        if (dist < 1e-4) continue;
        toL /= dist;
        const float cosEmitter = max(dot(-toL, lights.rectLights[li].normal), 0.0);
        if (cosEmitter <= 0.0) continue;
        const float area = length(cross(lights.rectLights[li].halfU,
                                        lights.rectLights[li].halfV)) * 4.0;
        const float geomTerm = cosEmitter * area / max(dist * dist, 0.01);
        const vec3 atten = traceFogShadowRay(x, toL, dist - 1e-2);
        const float ph = phaseHG(dot(wi, toL), g);
        addInscatter(nee, ph * lights.rectLights[li].color * geomTerm * atten);
    }

    // (c) Env NEE — uniform sphere sample. pdf = 1/(4π). Unbiased for constant-
    // luminance sky; high variance for peaked HDRIs (sun disk) which temporal
    // accumulation absorbs over many frames.
    {
        const float u1 = urand(seed);
        const float u2 = urand(seed);
        const float z  = 1.0 - 2.0 * u1;
        const float r  = sqrt(max(0.0, 1.0 - z * z));
        const float ph = 6.2831853 * u2;
        const vec3  dirE = vec3(r * cos(ph), r * sin(ph), z);
        const float pdfE = 1.0 / (4.0 * 3.14159265358979);
        const vec3 atten = traceFogShadowRay(x, dirE, 1e30);
        const vec3 Le    = sampleEquirectFog(dirE);
        const float phV  = phaseHG(dot(wi, dirE), g);
        addInscatter(nee, phV * Le * atten / pdfE);
    }

    return nee;
}

// ── Stratified single-scattering volumetric inscatter (primary camera ray) ──
// N=4 stratified depth samples along the segment, NEE to emissive tris, analytic
// lights, and the env. RESTORED from before the 2026-05-16 analog-integrator
// rewrite. The analog free-flight is unbiased over all scatter orders, but at
// 1-2 spp its binary scatter decision + HG phase sample make the CAMERA-segment
// single-scatter extremely grainy. This is an unbiased SINGLE-scatter estimator
// (truncated to single-scatter) and far quieter. raygen uses it for the primary
// segment only; secondary segments keep the analog free-flight (which carries
// the multi-scatter the camera segment drops — negligible for low-albedo fog).
vec3 volumeInscatter(vec3 rayOrigin, vec3 rayDir, float maxT, inout uint seed) {
    const float sigmaT = fog.sigmaT.x;
    if (sigmaT <= 0.0) return vec3(0.0);
    const float tMax  = min(maxT, 1e5);
    const float T_max = exp(-sigmaT * tMax);
    const float p1    = 1.0 - T_max;
    if (p1 < 1e-4) return vec3(0.0);

    // Estimator factor: σ_s·T(t)/p(t) = (σ_s/σ_t)·(1 − T_max).
    // fog.color is the single-scattering albedo σ_s/σ_t.
    const vec3  scatterFactor = fog.color * p1;
    const float g             = clamp(fog.anisotropy, -0.95, 0.95);

    const uint N = 4u;
    vec3 inscatter = vec3(0.0);

    for (uint i = 0u; i < N; ++i) {
        // Truncated free-flight, stratified ξ ∈ [i/N, (i+1)/N).
        const float xi = (float(i) + urand(seed)) / float(N);
        const float tScatter = -log(max(1.0 - xi * p1, 1e-30)) / sigmaT;
        const vec3  x        = rayOrigin + rayDir * tScatter;

        // (a) Emissive-tri NEE
        if (pc.emissiveCount > 0u && pc.emissiveTotalPower > 0.0) {
            const EmissiveSample es = sampleEmissiveTriCdfFog(seed);
            if (es.area > 1e-20 && es.power > 0.0) {
                vec3 toL = es.point - x;
                const float dist = max(length(toL), 1e-4);
                toL /= dist;
                const float cosLight = abs(dot(-toL, es.normal));
                if (cosLight > 1e-4) {
                    const vec3 atten = traceFogShadowRay(x, toL, dist - 1e-2);
                    const float pickPdf  = es.power / pc.emissiveTotalPower;
                    const float pdfArea  = pickPdf / es.area;
                    const float pdfOmega = pdfArea * dist * dist / cosLight;
                    if (pdfOmega > 1e-10) {
                        const float ph = phaseHG(dot(rayDir, toL), g);
                        addInscatter(inscatter, ph * es.emission * atten / pdfOmega);
                    }
                }
            }
        }

        // (b) Analytical lights — dir / point / spot / rect
        for (uint li = 0u; li < lights.dirCount; ++li) {
            const vec3 L = normalize(lights.dirLights[li].direction);
            const vec3 atten = traceFogShadowRay(x, L, 1e30);
            const float ph = phaseHG(dot(rayDir, L), g);
            addInscatter(inscatter, ph * lights.dirLights[li].color * atten);
        }
        for (uint li = 0u; li < lights.pointCount; ++li) {
            vec3 toL = lights.pointLights[li].position - x;
            const float dist = length(toL);
            if (dist < 1e-4) continue;
            toL /= dist;
            const float decay = lights.pointLights[li].decay;
            float att = 1.0 / max(pow(dist, decay), 0.1);
            const float range = lights.pointLights[li].range;
            if (range > 0.0) {
                const float t  = dist / range;
                const float t4 = t * t * t * t;
                const float w  = max(1.0 - t4, 0.0);
                att *= w * w;
            }
            const vec3 atten = traceFogShadowRay(x, toL, dist - 1e-2);
            const float ph = phaseHG(dot(rayDir, toL), g);
            addInscatter(inscatter, ph * lights.pointLights[li].color * att * atten);
        }
        for (uint li = 0u; li < lights.spotCount; ++li) {
            vec3 toL = lights.spotLights[li].position - x;
            const float dist = length(toL);
            if (dist < 1e-4) continue;
            toL /= dist;
            const float spotCos = dot(-toL, lights.spotLights[li].direction);
            const float spotAtten = smoothstep(lights.spotLights[li].cosAngleOuter,
                                               lights.spotLights[li].cosAngleInner,
                                               spotCos);
            if (spotAtten <= 0.0) continue;
            const float decay = lights.spotLights[li].decay;
            float att = 1.0 / max(pow(dist, decay), 0.1);
            const float range = lights.spotLights[li].range;
            if (range > 0.0) {
                const float t  = dist / range;
                const float t4 = t * t * t * t;
                const float w  = max(1.0 - t4, 0.0);
                att *= w * w;
            }
            att *= spotAtten;
            const vec3 atten = traceFogShadowRay(x, toL, dist - 1e-2);
            const float ph = phaseHG(dot(rayDir, toL), g);
            addInscatter(inscatter, ph * lights.spotLights[li].color * att * atten);
        }
        for (uint li = 0u; li < lights.rectCount; ++li) {
            const float ru = urand(seed) * 2.0 - 1.0;
            const float rv = urand(seed) * 2.0 - 1.0;
            const vec3 samplePos = lights.rectLights[li].position
                                 + ru * lights.rectLights[li].halfU
                                 + rv * lights.rectLights[li].halfV;
            vec3 toL = samplePos - x;
            const float dist = length(toL);
            if (dist < 1e-4) continue;
            toL /= dist;
            const float cosEmitter = max(dot(-toL, lights.rectLights[li].normal), 0.0);
            if (cosEmitter <= 0.0) continue;
            const float area = length(cross(lights.rectLights[li].halfU,
                                            lights.rectLights[li].halfV)) * 4.0;
            const float geomTerm = cosEmitter * area / max(dist * dist, 0.01);
            const vec3 atten = traceFogShadowRay(x, toL, dist - 1e-2);
            const float ph = phaseHG(dot(rayDir, toL), g);
            addInscatter(inscatter, ph * lights.rectLights[li].color * geomTerm * atten);
        }

        // (c) Env NEE — uniform sphere sample.
        {
            const float u1 = urand(seed);
            const float u2 = urand(seed);
            const float z  = 1.0 - 2.0 * u1;
            const float r  = sqrt(max(0.0, 1.0 - z * z));
            const float ph = 6.2831853 * u2;
            const vec3  dirE = vec3(r * cos(ph), r * sin(ph), z);
            const float pdfE = 1.0 / (4.0 * 3.14159265358979);
            const vec3 atten = traceFogShadowRay(x, dirE, 1e30);
            const vec3 Le    = sampleEquirectFog(dirE);
            const float phV  = phaseHG(dot(rayDir, dirE), g);
            addInscatter(inscatter, phV * Le * atten / pdfE);
        }
    }

    return inscatter * scatterFactor / float(N);
}

// shade_primary.glsl was the prior in-raygen primary shader; it had subtle
// divergences from chit. Replaced by the bounce-0-on-raster path further
// down in main() which calls into shade_common.glsl (included near the top
// of this file, after the bindings + push constant + payload declarations).

void main() {
    const uint spp = max(pc.samplesPerPixel, 1u);
    // Host-driven via VulkanRenderer::setMaxBounces. clamp to [1,16] so a
    // zero or absurd value can't break the bounce loop / kMaxSteps budget.
    const int kMaxBounces = int(clamp(pc.maxBounces, 1u, 16u));

    const vec2 size = vec2(gl_LaunchSizeEXT.xy);
    const vec4 originWS = cam.viewInverse * vec4(0.0, 0.0, 0.0, 1.0);

    // Per-pixel running snapshot of the chit's most-recent primaryAlbedo.
    // chit writes payload.primaryAlbedo per traceRayEXT; the LAST chit
    // that ran at primary supplies the value. Initialised to vec4(0)
    // → atrous treats as demod-disabled if no valid chit fired (sky,
    // pass-through-only paths).
    vec4 primaryAlbedoSnapshot = vec4(0.0);

    // Accumulator across in-frame samples. radianceSum is the SUM (not mean)
    // of per-sample radiance; the history blend below treats it as `spp`
    // effective samples (weight = spp), keeping FC arithmetic correct.
    vec3 radianceSum = vec3(0.0);
    // Companion sum of luminance² across spp samples — same effective-sample
    // weighting in the FC blend below produces M2 = mean(lum²). Variance
    // (read by atrous) is then M2 − luminance(mean)². Population form, not
    // divided by N: that's what the SVGF luminance edge stop wants.
    float lum2Sum = 0.0;

    // Captured the very first traceRayEXT of the FIRST sample. Used after the
    // loop to reproject this pixel's converged history. primaryInstanceId == 0
    // means sky / miss — no reproject (env is camera-locked, accumulates naively).
    vec3 primaryWorldPos   = vec3(0.0);
    // Per-vertex prev-frame world position at the primary hit. Filled by chit
    // via gdesc.prevVertexAddress interpolation. For static / rigid-only
    // meshes this equals primaryWorldPos (chit reads same buffer for both);
    // for skinned/displaced meshes it's the deformed position from the
    // previous frame. Reproject uses motionMat · primaryPrevWorldPos.
    vec3 primaryPrevWorldPos = vec3(0.0);
    uint primaryInstanceId = 0u;
    float primaryRoughness   = 1.0;// default (most lenient cap) until first real shade event
    float primaryMetalness   = 0.0;
    float primaryTransmission = 0.0;
    float primarySpecFrac    = 0.0;// chit-computed view-dep fraction; drives FC decay

    // Hybrid mode (gbuffer drives primary visibility): PT primary-ray jitter
    // is gated off — confirmed empirically (2026-05-06) that Monte Carlo
    // primary produces shake regardless of motion-vec accuracy. Raster owns
    // primary visibility (raster jitter on for AA).
    // Pulled from a specialization constant at pipeline-compile time, not
    // a per-frame push-constant read. The dead branch is DCEd from the SPV.
    const bool hybridOn = kHybridEnabled;

    // Debug timing knob. When set, the step + spp loops break out
    // immediately after the step-0 primary traceRayEXT and main() returns
    // before the post-loop history / accumulator writes. pathTraceMs then
    // reflects (primary trace + minimal payload setup + dispatch overhead),
    // letting us size the bounce-0-on-raster opportunity. Image goes black
    // while on; not meant for gameplay use.
    const bool measurePrimaryTraceOnly = (pc.motionFlags & 128u) != 0u;

    // Hybrid primary path: raster G-buffer determines visibility, but we let
    // chit handle primary shading by tracing a primary ray from camera origin
    // to the gbuf-derived surface direction. shade_primary.glsl's in-raygen
    // BSDF had subtle divergences from chit (basis-rotation bug, weight-form
    // numerics on low-roughness specular) that produced lower stills quality
    // than non-hybrid. Routing through chit collapses the two paths to one
    // BSDF implementation — hybrid quality matches non-hybrid by construction.
    //
    // The shake fix is preserved: per-frame raster Halton jitter is applied
    // to the primary NDC, the PT accumulator integrates the result across
    // frames, and FC reset on motion handles moving objects.
    vec3 primarySkyEnv     = vec3(0.0);
    bool primaryHybridSky  = false;// gbuffer says sky → tap env, terminate at step 0
    vec3 primaryDirHybrid  = vec3(0.0);// camera → pixel-center, unjittered
    if (hybridOn) {
        const vec2  uv_screen = (vec2(gl_LaunchIDEXT.xy) + 0.5) / size;
        const uvec4 idsTap    = texture(gbufIdsTex, uv_screen);
        const uint  id1       = idsTap.x;// 0 == sky/miss

        // Blue-noise sub-pixel jitter on primary direction, sampled from the
        // host-generated 64×64 void-and-cluster tile (binding 27). Adjacent
        // pixels share correlated values (silhouettes don't flutter, no
        // transform-wobble appearance on stopped textured bodies), globally
        // decorrelated (no coherent shake on moving objects). Temporal
        // animation: each frame reads a different tile cell per pixel,
        // cycling through the full sequence over ~64 frames → standard
        // temporal AA via PT accumulator.
        const vec2 jitterPx = vec2(
                blueNoise(gl_LaunchIDEXT.xy, pc.sampleIndex, 0u) - 0.5,
                blueNoise(gl_LaunchIDEXT.xy, pc.sampleIndex, 1u) - 0.5) * 0.5;
        // Pixel-space jitter → NDC: 1 pixel = 2/size in NDC.
        const vec2 jitterNdc  = jitterPx * 2.0 / size;
        const vec2  ndcCenter = vec2(uv_screen.x * 2.0 - 1.0 + jitterNdc.x,
                                     -(uv_screen.y * 2.0 - 1.0) - jitterNdc.y);
        const vec4 targetVS_c = cam.projInverse * vec4(ndcCenter, 1.0, 1.0);
        const vec3 dirVS_c    = normalize(targetVS_c.xyz / targetVS_c.w);
        primaryDirHybrid      = normalize((cam.viewInverse * vec4(dirVS_c, 0.0)).xyz);

        if (id1 == 0u) {
            primarySkyEnv    = sampleEquirectFog(primaryDirHybrid);
            primaryHybridSky = true;
        }
    }

    // Silhouette MSAA. 1-spp primary at a mesh/sky or mesh/mesh seam can't
    // represent fractional sub-pixel coverage — one jittered pick lands
    // fully on one side and atrous correctly refuses to bleed across the
    // depth/ID edge, leaving visible speckles. Detect such pixels and fire
    // EDGE_MSAA_EXTRA extra primaries there. Each extra sample reuses
    // the spp loop's per-sample blue-noise seed → naturally decorrelated
    // sub-pixel positions, no new RNG plumbing. Hybrid-only (non-hybrid
    // has no gbuf to read).
    //
    // Detection runs three tests on the 8-neighbourhood of the raster
    // prepass:
    //   (1) mesh-ID mismatch — classic silhouette (mesh-vs-mesh, mesh-vs-sky).
    //   (2) depth gradient — same mesh ID but a sharp depth crease (ship
    //       hull-plate folds, roof corners, pole bends). Threshold scales
    //       with centre depth so far surfaces don't false-positive on
    //       sub-pixel jitter.
    //   (3) diagonal neighbours — pure-diagonal seams (a panel corner
    //       where the only differing pixel is the diagonal one) were
    //       missed by the 4-cardinal test, leaving single-pixel
    //       speckles against the sky on bent geometry.
    bool isSilhouette = false;
    if (hybridOn) {
        const ivec2 cpx = ivec2(gl_LaunchIDEXT.xy);
        const ivec2 csz = ivec2(gl_LaunchSizeEXT.xy);
        const uint  idC = texelFetch(gbufIdsTex,   cpx, 0).x;
        const float zC  = texelFetch(gbufDepthTex, cpx, 0).x;
        // Depth-gradient tolerance: 1 % of centre depth, with a 1e-3
        // absolute floor so near-plane geometry (zC small) doesn't fire
        // on sub-pixel jitter alone. Far surfaces (zC → 1) get a looser
        // tolerance which avoids false positives on slopes.
        const float depthEps = max(1e-3, zC * 0.01);
        // 8-neighbourhood: 4 cardinals followed by 4 diagonals. Order
        // matters slightly — cardinals are more likely to differ on a
        // typical silhouette so they short-circuit first.
        const ivec2 off8[8] = ivec2[8](
                ivec2( 1,  0), ivec2(-1,  0), ivec2( 0,  1), ivec2( 0, -1),
                ivec2( 1,  1), ivec2(-1, -1), ivec2( 1, -1), ivec2(-1,  1));
        for (int k = 0; k < 8; ++k) {
            const ivec2 p   = clamp(cpx + off8[k], ivec2(0), csz - ivec2(1));
            const uint  idN = texelFetch(gbufIdsTex,   p, 0).x;
            if (idN != idC) {
                isSilhouette = true;
                break;
            }
            // Same mesh ID: check for a sharp depth crease (corner /
            // self-occlusion edge). Sky pixels (idC == 0) all share
            // depth ≈ 1 so this branch never fires on a sky run.
            const float zN = texelFetch(gbufDepthTex, p, 0).x;
            if (abs(zN - zC) > depthEps) {
                isSilhouette = true;
                break;
            }
        }
    }
    // Per-pixel MSAA budget at detected silhouettes. Runtime-tunable via
    // VulkanRenderer::setSilhouetteMsaaExtra(N) — 0 disables, N gives
    // (N+1)× total samples at edge pixels. Default 7 → 8× MSAA. The
    // primary cache stays disabled at silhouettes (each sub-sample
    // re-traces the full chit), so each extra sample is a full primary
    // shade including NEE / RIS / GI. Edge pixels are typically 5–15 %
    // of frame, so absolute cost scales gently with the knob.
    const uint effSpp = spp + (isSilhouette ? pc.edgeMsaaExtra : 0u);

    // Per-spp loop optimization controls.
    //   canCachePrimary: hybrid + !perSppJitter means primary direction is
    //     identical across spp samples → primary chit's NEE/RIS/GI/caustic
    //     gather (which depend on the surface, not bs.dir) can be computed
    //     once at s=0 and reused for s>=1 via inFlags bit 5 (BSDF_ONLY).
    //     Disabled at silhouettes — each MSAA sub-sample needs its own
    //     primary direction + fresh chit shade (different surface visible
    //     at different sub-pixel positions, by definition).
    //   primaryHybridSky early-out below covers the sky-pixel case
    //     separately so the loop can skip entirely.
    const bool perSppJitter   = (pc.motionFlags & 32u) != 0u;
    const bool canCachePrimary = hybridOn && !perSppJitter && !isSilhouette;
    vec3 cachedDirect = vec3(0.0);

    // Hybrid sky early-out: gbuf at this pixel is sky → primary direction is
    // fixed (primaryDirHybrid), env tap is deterministic, and the path
    // terminates at step 0. Replace the spp loop with one sky evaluation
    // scaled by spp. Disabled when fog is enabled — the unbiased in-loop
    // volumetric integrator needs per-spp scatter samples (each spp may
    // scatter at a different depth + direction), so we fall through to the
    // regular spp loop which performs the correct integration.
    if (hybridOn && primaryHybridSky && !fogEnabled() && !isSilhouette) {
        const float sppF   = float(spp);
        radianceSum        = primarySkyEnv * sppF;
        const float lumSky = dot(primarySkyEnv, vec3(0.2126, 0.7152, 0.0722));
        lum2Sum            = lumSky * lumSky * sppF;
    } else
    for (uint s = 0u; s < effSpp; ++s) {
        // Per-sample sub-frame index — each in-frame sample needs its own
        // jitter and seed to actually decorrelate. spp (not effSpp) keeps
        // the Halton/blue-noise stride invariant — silhouette MSAA samples
        // (s ≥ spp) draw the next slots in the same global sequence.
        const uint subIdx = pc.sampleIndex * spp + s;
        const uint sIdx   = subIdx + 1u;
        // Sub-pixel jitter source.
        //   canCachePrimary (hybrid + !perSppJitter + !isSilhouette): no jitter
        //     — the cached primary direction is shared across spp.
        //   isSilhouette: deterministic stratified pattern. Sub-pixel
        //     coverage at edges has to be sampled accurately, not
        //     stochastically — Halton-style jitter on 4–8 samples can
        //     cluster on one side of a thin feature, producing the
        //     dotted-line / sawtooth pattern that no amount of post-AA
        //     can recover. The 4×4 stratified grid below guarantees one
        //     sample per sub-pixel cell up to s=15, so a 30 %-coverage
        //     wire gets ~5/16 hits every frame regardless of frame index
        //     or pixel position. Temporal Halton offset on top keeps
        //     samples decorrelated across frames so TAA can still build
        //     history. For s ≥ 16 (unlikely with default extras=7), wrap
        //     back to Halton.
        //   otherwise (non-hybrid, perSppJitter on flat surface): standard
        //     blue-noise jitter from the void-and-cluster tile.
        vec2 jitter;
        if (canCachePrimary) {
            jitter = vec2(0.0);
        } else if (isSilhouette) {
            // Stratified grid sized so the FULL pixel is covered by effSpp
            // samples — covering only a portion would miss sub-pixel features
            // in the unsampled region (a horizontal edge in the top half of
            // the pixel reports 0 % coverage if all samples land in the
            // bottom half → staircase). Power-of-2 dimensions for bit-shift
            // indexing.
            //   effSpp ≤ 2:  2×1  (2 cols, 1 row)
            //   effSpp ≤ 4:  2×2
            //   effSpp ≤ 8:  4×2  (default — base spp=1 + extras=7)
            //   effSpp ≤ 16: 4×4
            //   effSpp > 16: 8×4
            uint colsLog2, rowsLog2;
            if      (effSpp <= 2u)  { colsLog2 = 1u; rowsLog2 = 0u; }
            else if (effSpp <= 4u)  { colsLog2 = 1u; rowsLog2 = 1u; }
            else if (effSpp <= 8u)  { colsLog2 = 2u; rowsLog2 = 1u; }
            else if (effSpp <= 16u) { colsLog2 = 2u; rowsLog2 = 2u; }
            else                    { colsLog2 = 3u; rowsLog2 = 2u; }
            const uint colMask = (1u << colsLog2) - 1u;
            const uint rowMask = (1u << rowsLog2) - 1u;
            const uint cellX = s & colMask;
            const uint cellY = (s >> colsLog2) & rowMask;
            // Per-frame Halton offset within each cell so TAA history sees
            // fresh sub-cell positions across frames (within-frame stratified,
            // across-frame randomised).
            const float tx = blueNoise(gl_LaunchIDEXT.xy, sIdx, 0u);
            const float ty = blueNoise(gl_LaunchIDEXT.xy, sIdx, 1u);
            const float invCols = 1.0 / float(1u << colsLog2);
            const float invRows = 1.0 / float(1u << rowsLog2);
            jitter = vec2(
                    (float(cellX) + tx) * invCols - 0.5,
                    (float(cellY) + ty) * invRows - 0.5);
        } else {
            jitter = vec2(blueNoise(gl_LaunchIDEXT.xy, sIdx, 0u) - 0.5,
                          blueNoise(gl_LaunchIDEXT.xy, sIdx, 1u) - 0.5);
        }

        const vec2 pix = vec2(gl_LaunchIDEXT.xy) + 0.5 + jitter;
        vec2 ndc = pix / size * 2.0 - 1.0;
        ndc.y = -ndc.y;

        const vec4 targetVS = cam.projInverse * vec4(ndc, 1.0, 1.0);
        const vec3 dirVS = normalize(targetVS.xyz / targetVS.w);
        const vec3 dirWS = normalize((cam.viewInverse * vec4(dirVS, 0.0)).xyz);

        uint seed = seedFor(gl_LaunchIDEXT.xy, subIdx);

        vec3 radiance   = vec3(0.0);
        vec3 throughput = vec3(1.0);
        vec3 origin     = originWS.xyz;
        // Hybrid + cacheable primary: every spp uses the same gbuf-derived
        // primary direction. Otherwise (non-hybrid, perSppJitter, or
        // silhouette MSAA): each spp gets its own jittered direction so
        // the sub-pixel samples actually integrate fractional coverage.
        vec3 dir        = canCachePrimary ? primaryDirHybrid : dirWS;
        // True when the prior shade event ran env NEE — used to gate the MIS
        // half-env weight on the next miss. Transmission events skip NEE and
        // clear this so the env is read at full strength on the bounce-into-miss.
        bool prevRanNEE = false;

        // scatter counts real shade events (non-transmission). Transmission hops
        // (glass enter/exit, single-sided pass-through — flags bit 2) are free and
        // don't consume the scatter budget, so multi-layer glass doesn't exhaust
        // the bounce limit before reaching the surface behind it.
        int scatter = 0;
        bool prevPassThrough = false;
        // Init bsdfPdf once per sample. Persists across step iterations so the
        // most recent shade event's pdf survives into the next step where miss
        // (or chit) can read it for env CDF MIS weighting.
        payload.bsdfPdf = 0.0;
        // Camera ray starts in air (ior=1.0). Closed-glass refractions update
        // this on the way in / out so the BSDF can compute eta from the actual
        // current medium rather than guessing from geometric isFront. Assumes
        // the camera origin is in air; if the user places the camera literally
        // inside a glass volume, this is wrong (rare and out of scope here).
        payload.currentIor = 1.0;
        // Adaptive bounce cap: diffuse / glossy primary surfaces stop gaining
        // visible detail after a few indirect bounces, so cap them short for a
        // large perf win on production scenes (~5 FPS on Sponza per WGPU memory).
        // Re-evaluated each step since the FIRST step classifies primary into
        // primaryRoughness/Metalness/Transmission. Mirror / metal / glass keep
        // the full budget. Cap is BIASED — truncates the Neumann-series energy
        // sum and causes ρ≈1 cavities to under-read; gate on
        // pc.fireflyClamp > 1e20 (= setFireflyClamp(0)) when an unbiased mode
        // is wanted.
        int effectiveBounces = kMaxBounces;
        // True once a medium scatter event has fired on this path; suppresses
        // primary-hit capture (a post-scatter surface is not the camera-ray's
        // first surface, so it isn't a valid reproject anchor).
        bool mediumScattered = false;
        for (int step = 0; step < kMaxSteps; ++step) {
            // Recompute each step — primary classification settles after first hit.
            {
                const bool isGlass  = primaryTransmission > 0.05;
                const bool isMetal  = primaryMetalness    > 0.5;
                const bool isMirror = primaryRoughness    < 0.22; // alpha≈0.05
                const bool isGlossy = primaryRoughness    < 0.50; // alpha≈0.25
                if (!isGlass && !isMetal && !isMirror) {
                    effectiveBounces = isGlossy ? min(kMaxBounces, 4) : min(kMaxBounces, 3);
                } else {
                    effectiveBounces = kMaxBounces;
                }
                // Dense-medium cap: when the path is inside a scattering medium
                // (underwater ocean fog, thick atmospheric haze), the bounce
                // loop fires many extra iterations because every segment may
                // scatter. Multi-scatter contribution falls off via
                // Beer-Lambert anyway, so single-scatter captures most of the
                // god-ray visual. Profiling showed PT megakernel went from
                // 5.5ms above-water to 26.2ms underwater on vulkan_ocean —
                // capping bounces here is the lever that targets that delta.
                if (fogEnabled() && fog.sigmaT.x > 0.01) {
                    effectiveBounces = min(effectiveBounces, 2);
                }
            }
        payload.radianceDiff = vec3(0.0);
        payload.radianceSpec = vec3(0.0);
        payload.brdfWeight = vec3(0.0);
        payload.nextOrigin = vec3(0.0);
        payload.nextDir    = vec3(0.0);
        // Bit 1 = "halve env on miss" (MIS partner of the prior NEE shadow ray).
        // We only set it when the previous shade actually ran NEE; otherwise
        // (primary, or after a transmission event) the next env miss must
        // contribute at full weight to stay unbiased.
        payload.flags      = prevRanNEE ? 2u : 0u;
        payload.seed       = seed;
        payload.hitWorldPos    = vec3(0.0);
        payload.prevWorldPos   = vec3(0.0);
        payload.hitInstanceId  = 0u;
        payload.hitRoughness   = 1.0;
        payload.hitMetalness   = 0.0;
        payload.hitTransmission = 0.0;
        payload.hitSpecFrac    = 0.0;
        payload.primaryAlbedo  = vec4(0.0);
        payload.hitNormal      = vec3(0.0);
        // NOTE: bsdfPdf is intentionally NOT reset here — it must persist from
        // the previous step's chit (which wrote it for the bounce direction we
        // are about to trace) so the miss handler can compute MIS for env CDF.
        // Resetting to 0 every step zeros the env-via-bounce contribution and
        // makes glass→sky / scattered→sky paths render too dark on HDRI scenes.
        // Initialised once per sample below (before the inner step loop).
        // bit 0 of inFlags: "this hit's surface emission was already covered
        // by the prior shade's emissive-NEE shadow ray, so suppress it here".
        // Cleared on primary (scatter==0) and after pass-through hops (those
        // don't perform NEE, so the next shade event must keep emission).
        // bit 5 (= 32u) of inFlags = "BSDF_ONLY" — set on primary trace
        // (step==0) for spp samples 1..spp-1 when canCachePrimary is on.
        // The chit reads this to skip NEE / RIS / GI / caustic gather (those
        // depend on the surface, not bs.dir) and only sample BSDF + write
        // bounce-continuation payload. raygen injects the cached direct
        // contribution from s=0 via the override below the trace.
        payload.inFlags    = ((scatter > 0 && !prevPassThrough && pc.emissiveCount > 0u) ? 1u : 0u)
                           | ((canCachePrimary && step == 0 && s > 0u) ? 32u : 0u)
                           | ((scatter > 0) ? 128u : 0u);// ≥1 real scatter → secondary hit (DDGI "1 bounce + tail")

        // tmin selection: shaded bounces use 0.001 (1mm) to avoid self-
        // intersection acne on the surface we just left. Pass-through hops
        // (alpha-blend, alpha-test cutout, single-sided back-face) need a
        // much smaller tmin — a decal sitting on a host mesh is sub-mm away,
        // so 0.001 would skip the host and the pass-through rays would punch
        // straight through the model into interior/sky, producing firefly
        // splatter inside the decal silhouette.
        const float tmin = prevPassThrough ? 1e-4 : 0.001;

        // Hybrid sky early-out: gbuf at this pixel said miss, so skip the
        // primary traceRay and use the precomputed env tap. Non-sky hybrid
        // pixels fall through to the same traceRayEXT non-hybrid uses; chit
        // handles primary shading exactly the same way (`dir` was set to
        // `primaryDirHybrid` above so the ray hits the gbuf-rasterized
        // surface).
        bool primaryViaHybrid = false;
        if (hybridOn && step == 0 && primaryHybridSky) {
            payload.radianceDiff    = primarySkyEnv;
            payload.radianceSpec    = vec3(0.0);
            payload.brdfWeight      = vec3(0.0);
            payload.nextOrigin      = vec3(0.0);
            payload.nextDir         = vec3(0.0);
            payload.flags           = 1u;
            payload.hitWorldPos     = origin + dir * 1e6;
            payload.prevWorldPos    = origin + dir * 1e6;// sky has no prev — same as current
            payload.hitInstanceId   = 0u;
            payload.hitRoughness    = 1.0;
            payload.hitMetalness    = 0.0;
            payload.hitTransmission = 0.0;
            payload.bsdfPdf         = 0.0;
            payload.currentIor      = 1.0;
            payload.hitSpecFrac     = 0.0;
            payload.primaryAlbedo   = vec4(0.0);
            payload.hitNormal       = vec3(0.0);// hybrid sky early-out — no surface normal
            primaryViaHybrid = true;
        }


        // No OpaqueEXT — alpha-test materials need the any-hit shader to fire.
        // Materials with alphaCutoff <= 0 short-circuit in the any-hit shader.
        if (!primaryViaHybrid) {
#ifdef SER
            // SER path: split BVH traversal from closest-hit invocation. The
            // hitObject captures traversal result + barycentrics + instance
            // info WITHOUT firing any shader; reorderThreadNV then rebalances
            // the warp so neighbouring threads sharing a material asset fire
            // the same chit branch coherently.
            //
            // Material-hint variant (not the naive `reorderThreadNV(hit)`):
            // threepp uses ONE monolithic closest_hit that branches on
            // metalness / transmission / clearcoat / emissive internally, so
            // reordering by hit-instance alone leaves divergent material code
            // inside the chit and the indirection becomes net-negative —
            // measured as a regression when ReSTIR GI is on (Stage 2's
            // recursive sub-trace amplifies the chit cost). Pre-fetching
            // mats[i].materialAssetIdx and feeding it as the reorder hint
            // groups threads by *material branch*, which is what a single-
            // chit pipeline needs. 8 hint bits = 256 buckets; matAssetMap
            // typically yields ≤ ~50 unique materials per scene. matHint=0
            // is reserved for misses so sky threads cluster together.
            hitObjectNV hit;
            hitObjectRecordEmptyNV(hit);
            hitObjectTraceRayNV(hit, topAS, gl_RayFlagsNoneEXT, 0xff, 0, 0, 0,
                                origin, tmin, dir, 10000.0, 0);
            uint matHint = 0u;
            if (hitObjectIsHitNV(hit)) {
                const uint instIdx = uint(hitObjectGetInstanceCustomIndexNV(hit));
                matHint = mats[instIdx].materialAssetIdx + 1u;
            }
            reorderThreadNV(hit, matHint, 8);
            hitObjectExecuteShaderNV(hit, 0);
#else
            traceRayEXT(topAS, gl_RayFlagsNoneEXT, 0xff, 0, 0, 0,
                        origin, tmin, dir, 10000.0, 0);
#endif
        }

        // Measurement gate: exit the step loop immediately after step-0
        // primary trace so pathTraceMs isolates the primary-trace cost.
        // Placed AFTER the trace so the actual traversal+chit work runs
        // and is included in the timing. The outer spp loop continues so
        // silhouette MSAA inflation is reflected in the measurement.
        if (measurePrimaryTraceOnly && step == 0) break;

        // ─── Unbiased volumetric path step ──────────────────────────────────
        // Analog free-flight sampling. Given current segment of length tSurf
        // (distance to surface hit, or atmospheric cap on env miss), sample a
        // scatter distance tScatter ~ Exp(σ_t). If tScatter < tSurf, the path
        // scatters in the medium at x = origin + dir*tScatter; otherwise it
        // proceeds to the surface (or env). The Beer-Lambert factor and the
        // distance pdf cancel exactly in the analog estimator, so no explicit
        // exp() reweighting is needed at the scatter event — only at surface
        // events (the no-scatter probability, applied to throughput).
        //
        // Reference: PBRT v4 §11.3 (Pharr/Jakob/Humphreys, 2023).
        //
        // Hybrid-sky early-out also goes through this block: the hybrid path
        // sets payload.hitInstanceId = 0 and payload.hitWorldPos far away
        // (origin + dir·1e6), so tSurf falls into the env-miss branch (1e6).
        // Scatter can still win, yielding in-medium in-scatter on otherwise-
        // sky-only hybrid pixels.
        if (fogEnabled() && fog.sigmaT.x > 1e-8) {
            const bool  isEnvMiss = (payload.hitInstanceId == 0u);
            const float tSurf     = isEnvMiss
                    ? 1e6
                    : distance(origin, payload.hitWorldPos);
            // Length of the medium-active portion of this segment. Honours the
            // water-column waterSurfaceY clip and the env-miss atmospheric cap.
            const float mediumLen = fogSegmentLength(origin, dir, tSurf, isEnvMiss);

            // Primary camera segment (step 0): use the quiet stratified single-
            // scatter overlay instead of the grainy analog scatter. The analog's
            // binary scatter decision + HG phase sample at 1-2 spp is the
            // dominant source of visible fog noise, and it's worst on the camera
            // ray. The camera ray then proceeds to the surface (a valid reproject
            // anchor) with Beer-Lambert applied past the medium segment; multi-
            // scatter on the camera segment itself is dropped (negligible for the
            // low-albedo fog this targets). Secondary segments (step >= 1) keep
            // the unbiased analog free-flight below, so indirect-through-fog
            // multi-scatter is preserved.
            if (step == 0) {
                radiance   += throughput * volumeInscatter(origin, dir, mediumLen, seed);
                throughput *= fogTransmittance(mediumLen);
            } else {
            const float xi        = urand(seed);
            const float tScatter  = -log(max(1.0 - xi, 1e-30)) / fog.sigmaT.x;

            if (tScatter < mediumLen) {
                // Scatter event in the medium. The post-scatter surface (if any
                // later in the path) is NOT a valid primary-reproject anchor.
                mediumScattered = true;

                // Albedo factor σ_s/σ_t = fog.color (single-scattering albedo).
                throughput *= fog.color;

                const vec3  x = origin + dir * tScatter;
                const float g = clamp(fog.anisotropy, -0.95, 0.95);

                // In-medium NEE (one shadow ray per light source).
                const vec3 Ld = volumeNeeSingle(x, dir, g, seed);
                vec3 contribution = throughput * Ld;
                // Post-multiply firefly clamp — env / emitter-PDF spikes
                // amplified by throughput need bounding (mirrors the env-NEE
                // post-multiply pattern used for surfaces).
                if (pc.fireflyClamp < 1e20) {
                    const float cap = pc.fireflyClamp * 1.5;
                    const float lum = dot(contribution, vec3(0.2126, 0.7152, 0.0722));
                    if (lum > cap) contribution *= cap / lum;
                }
                radiance += contribution;

                // Sample next direction from the phase function. For analog
                // sampling, phase·pdf cancels exactly, so no throughput factor
                // is needed here.
                const vec2 u2     = vec2(urand(seed), urand(seed));
                const vec3 newDir = sampleHG(dir, g, u2);
                // Persist phase pdf as bsdfPdf so the next miss (if the new dir
                // exits the scene) gets a balance-heuristic env-NEE MIS weight
                // approximately right. Strict MIS at scatter events would use
                // the phase pdf as one strategy and env-NEE as the other; we
                // only do NEE here, so this is a best-effort fallback.
                payload.bsdfPdf = phaseHG(dot(dir, newDir), g);

                origin = x;
                dir    = newDir;

                // Scatter consumes a bounce; RR after the 2nd scatter.
                ++scatter;
                if (scatter >= effectiveBounces) break;
                if (max(max(throughput.r, throughput.g), throughput.b) < 1e-4) break;
                if (scatter >= 2) {
                    const float p = clamp(max(max(throughput.r, throughput.g),
                                              throughput.b),
                                          0.05, 0.95);
                    if (urand(seed) > p) break;
                    throughput /= p;
                }

                prevRanNEE      = true;  // NEE was performed at this scatter point
                prevPassThrough = false; // scatter is not a pass-through hop
                continue;
            }

            // No scatter on this segment: apply Beer-Lambert over the medium-
            // active portion only. The remainder of the segment (e.g. above-
            // water portion of a ray exiting the water column, or anything
            // past the env-miss atmospheric cap) is treated as clear air.
            throughput *= fogTransmittance(mediumLen);
            }// end secondary-segment (step >= 1) analog free-flight
        }

        // Capture the primary hit (first iteration only) for reprojection
        // + adaptive bounce classification. Transmission hops and back-face
        // pass-throughs aren't real shade events — they don't tag a stable
        // surface — so we wait until the first non-pass-through hit (or
        // accept 0/sky if we never get one). Skipped once the path scattered
        // in the medium: the next surface seen is a post-scatter surface, not
        // the camera ray's first surface, so reproject anchored on it would be
        // wrong.
        if (primaryInstanceId == 0u && payload.hitInstanceId != 0u && !mediumScattered) {
            primaryWorldPos     = payload.hitWorldPos;
            primaryPrevWorldPos = payload.prevWorldPos;
            primaryInstanceId   = payload.hitInstanceId;
            primaryRoughness    = payload.hitRoughness;
            primaryMetalness    = payload.hitMetalness;
            primaryTransmission = payload.hitTransmission;
            primarySpecFrac     = payload.hitSpecFrac;
            primaryAlbedoSnapshot = payload.primaryAlbedo;
        }

        // BSDF_ONLY cache logic. At step 0 (primary) under canCachePrimary:
        //   s == 0 → record the primary's direct contribution (NEE + RIS + GI
        //            + caustic + ambient + emissive) for re-injection.
        //   s >= 1 → chit returned radianceDiff = 0 (BSDF_ONLY); inject the
        //            cached direct so this sample gets the same direct term
        //            (variance reduction sacrificed on direct, preserved on
        //            indirect since each sample's bs.dir is fresh).
        if (canCachePrimary && step == 0 && !primaryViaHybrid) {
            if (s == 0u) {
                cachedDirect = payload.radianceDiff + payload.radianceSpec;
            } else {
                payload.radianceDiff = cachedDirect;
                payload.radianceSpec = vec3(0.0);
            }
        }

        // Per-bounce firefly clamp on the contribution that lands in the
        // radiance accumulator. Two pre-existing failure modes drive the
        // very bright spikes:
        //   1. Russian Roulette can scale `throughput` up to ~20× to keep
        //      survivors unbiased. A subsequent bounce hitting a bright
        //      source (sun, near-source analytic-light NEE, emissive face)
        //      splats throughput·radiance with luminance in the thousands —
        //      one outlier sample dominates the running mean for many frames.
        //   2. Narrow-lobe BSDF samples (rough ≈ 0, p_spec near 1) divide
        //      F·cos by a tiny pdf, producing per-sample multipliers well
        //      above 1 even before RR.
        // Cap chosen at 50 luminance: low enough to crush ~1000-luminance
        // fireflies (≥20× compression) but high enough to preserve the
        // ~25-100 luminance values produced by legitimate bright
        // highlights (chrome near a strong analytic light, glossy bounce
        // off a sunlit surface). Primary view (scatter==0) is left
        // unclamped so directly-visible emissive surfaces and the
        // background-through-glass case stay at full intensity.
        // Phase 1: sum diff+spec for the existing single-channel accumulator.
        // Phase 2 will split into separate accumImages per channel.
        vec3 contribution = throughput * (payload.radianceDiff + payload.radianceSpec);
        if (scatter > 0 && pc.fireflyClamp < 1e20) {
            // Tie indirect-bounce cap to fireflyClamp so a tightened
            // user-facing clamp (Ocean demo sets 6) reaches the indirect
            // path too. Earlier hardcoded 50 was brighter than fireflyClamp,
            // letting BSDF-sample→miss→sun-disc fireflies stay visible even
            // when the user explicitly dialled the clamp down. 1.5× factor
            // gives indirect bounces a bit more room than direct NEE
            // (legitimate glossy reflections of bright surfaces want some
            // headroom — a polished metal viewed through a slight bounce
            // shouldn't get crushed as hard as a primary NEE outlier would).
            const float cap = pc.fireflyClamp * 1.5;
            const float lum = dot(contribution, vec3(0.2126, 0.7152, 0.0722));
            if (lum > cap) contribution *= cap / lum;
        }
        radiance += contribution;
        if ((payload.flags & 1u) != 0u) break;

        throughput *= payload.brdfWeight;
        if (max(max(throughput.r, throughput.g), throughput.b) < 1e-4) break;

        seed = payload.seed;
        // Bit 2 set means the hit was a transmission event with NEE skipped.
        // Carry that into the next iteration's MIS gate.
        prevRanNEE = (payload.flags & 4u) == 0u;

        // Transmission/pass-through events (glass refraction, single-sided
        // back-face, BLEND pass-through) do not count as scatter bounces.
        const bool isPassThrough = (payload.flags & 4u) != 0u;
        prevPassThrough = isPassThrough;
        if (!isPassThrough) {
            ++scatter;
            if (scatter >= effectiveBounces) break;

            // Russian Roulette: after the first indirect scatter, terminate paths
            // stochastically based on remaining throughput. Survivors are scaled
            // by 1/p_continue so the estimator stays unbiased. The 0.05 floor
            // keeps the variance from the inverse-prob scale-up bounded; the
            // 0.95 ceiling makes sure RR can still kill bright-but-fully-absorbed
            // tail paths.
            if (scatter >= 2) {
                const float p = clamp(max(max(throughput.r, throughput.g),
                                          throughput.b),
                                      0.05, 0.95);
                if (urand(seed) > p) break;
                throughput /= p;
            }
        }

        origin = payload.nextOrigin;
        dir    = payload.nextDir;
        }// end inner step loop

        // Volumetric attenuation + in-scattering are folded into the in-loop
        // path-integrator above (per-segment Beer-Lambert on throughput, per-
        // scatter-event NEE + HG phase sample). The water-column waterSurfaceY
        // clip is honoured at each segment via fogSegmentLength().

        radianceSum += radiance;
        // Luminance is a linear function of color, so luminance(mean(rgb)) ==
        // mean(luminance(rgb_s)). We can compute lum² here from the per-sample
        // radiance (post-firefly-clamp, post-fog) and the FC blend below will
        // yield M2 = mean(lum²) consistent with M1 = luminance(mean rgb).
        const float lumS = dot(radiance, vec3(0.2126, 0.7152, 0.0722));
        lum2Sum += lumS * lumS;
    }// end outer spp loop

    // Measurement-mode early-out: skip reproject + accumulator / gbuf /
    // albedo / motion-mat writes. pathTraceMs from the surrounding
    // timestamp pair already includes only the spp-loop body (primary
    // trace) above; downstream passes operate on stale data which is fine
    // for a few-frame timing read.
    if (measurePrimaryTraceOnly) return;

    // ── history tap (mirrors WGPU PT design) ─────────────────────────────
    // Per-pixel motion gating, matching WGPU's primaryMoved logic:
    //
    //  Static frame OR foreign mesh moved (this pixel's mesh static, camera
    //  static): self-tap. Bit-for-bit reuse of prev accum at the same pixel,
    //  FC unchanged. A single moving rigid body no longer halves FC scene-wide;
    //  background pixels accumulate cleanly even while another mesh animates.
    //
    //  This pixel's mesh moved OR camera moved (non-sky):
    //    Bilinear 4-tap reprojection. Each of the 4 bilinear corners is
    //    weighted by its bilinear fraction IF its prev-frame mesh-ID matches
    //    the current pixel's ID, otherwise zero weight. wSum > 1e-4 means at
    //    least one tap agreed → accept the weighted blend, halve FC so the
    //    running mean re-locks to the new viewpoint in ~16 frames. motionMat
    //    is identity for static meshes, so cam-only motion still reprojects
    //    correctly via prevCam* without per-mesh transform.
    //
    //  Sky pixel + camera moved: histFc=0 → cold-start (sky dir changed).
    //  Sky pixel + only foreign-mesh motion: self-tap above (sky unchanged).
    //
    // FC / mesh-ID packed as plain float in accum.w / gbuf.w. Small integers
    // (FC ≤ 4096, instance IDs ≤ 2^24) round-trip exactly through float32.
    // Do NOT use uintBitsToFloat/floatBitsToUint — NVIDIA RT shaders flush
    // subnormal bit patterns to zero, making the guard fail every frame.
    const ivec2 px = ivec2(gl_LaunchIDEXT.xy);
    const ivec2 sz = ivec2(gl_LaunchSizeEXT.xy);

    float histFc   = 0.0;
    vec3  histMean = vec3(0.0);
    // Companion to histMean: prev-frame mean(lum²). Same FC weight in the
    // final blend yields M2_new = (histLum2·histFc + lum2Sum)/(histFc+sppF).
    float histLum2 = 0.0;
    // Companion to histMean: prev-frame primary-surface albedo. Same
    // reproject path + same FC weight in the final blend yields a
    // temporally-consistent albedo channel so demod division stays stable
    // under motion. .a tracks whether prev-frame's snapshot was valid.
    vec3  histAlbedoRGB = vec3(0.0);
    float histAlbedoA   = 0.0;

    const uint primaryMeshU = (primaryInstanceId != 0u) ? (primaryInstanceId - 1u) : 0xFFFFFFFFu;
    const bool primaryMoved = isMeshMoved(primaryMeshU);
    const bool camMoved     = (pc.motionFlags & 2u) != 0u;

    // Stable material-asset id at this pixel (deduplicated by Material* in
    // the renderer). Tiled walls built from multiple Mesh objects sharing one
    // Material C++ object all carry the same value here, so the bilinear
    // reproject gate below can accept their cross-mesh taps instead of
    // cold-starting the seam between every adjacent tile during camera
    // motion. Sky/miss → sentinel that never compares equal to a real one.
    const uint primaryMatAssetIdx = (primaryInstanceId != 0u)
            ? mats[primaryMeshU].materialAssetIdx
            : 0xFFFFFFFFu;

    if ((pc.motionFlags & 1u) == 0u || (!primaryMoved && !camMoved)) {
        // ── Static for this pixel: self-tap ───────────────────────────
        //
        // Targeted validation: cold-start only when the prev frame's gbuf
        // at this exact pixel held a DIFFERENT surface AND that prev
        // surface was a moved mesh. This catches the wispy ghost trails
        // that surround animated skinned meshes (curr=sky, prev=robot
        // which moved away) without sacrificing accumulation on AA
        // silhouettes of static surfaces (where the same wall vs sky
        // alternate between frames due to camera-jitter — neither side
        // actually moved, so we should keep smoothing).
        // motionFlags bit 0 == 0 means no instance moved at all → skip the
        // load (saves a fetch) and trust the self-tap unconditionally.
        bool selfTapValid = true;
        if ((pc.motionFlags & 1u) != 0u) {
            const uint prevMeshHere = uint(imageLoad(prevGbufImage, px).w);
            if (prevMeshHere != primaryInstanceId &&
                prevMeshHere != 0u &&
                isMeshMoved(prevMeshHere - 1u)) {
                selfTapValid = false;
            }
        }
        // Sky pixels (primaryInstanceId == 0 → no sample hit a surface) get
        // no benefit from temporal accumulation: the env is already smooth
        // and low-variance, and accumulating across frames CARRIES FORWARD
        // any sub-pixel-jittered surface radiance that may have leaked into
        // accumImage on prior frames when the now-moved mesh was closer.
        // Forcing fresh-radiance here breaks the chain → no slow-decay
        // "fan of past positions" ghost behind moving URDF child links.
        // Surface pixels keep their accumulator path (which is what we want
        // for noise reduction on actual shaded surfaces).
        if (primaryInstanceId == 0u) {
            selfTapValid = false;
        }
        if (selfTapValid) {
            const vec4 pa = imageLoad(prevAccumImage, px);
            const vec3 m  = pa.rgb;
            if (!any(isnan(m)) && !any(isinf(m))) {
                histMean = m;
                histFc   = pa.w;
                // Same self-tap pixel for moments; finite-check ensures we
                // don't propagate a NaN into the variance estimate (atrous'
                // σ_lum would explode).
                const float pm = imageLoad(prevMomentsImage, px).r;
                if (!isnan(pm) && !isinf(pm)) histLum2 = pm;
                // Same self-tap for prev albedo.
                const vec4 pal = imageLoad(prevPrimaryAlbedoImage, px);
                histAlbedoRGB = pal.rgb;
                histAlbedoA   = pal.a;
            }
        } else {
            // 2026-05-13: hard cold-start when prev pixel held a now-vacated
            // moving mesh (selfTapValid==false case). Was previously damped
            // to histFc=4 to keep silhouette AA smooth, but the old mesh
            // color contributing ~80% for several frames left visible trails
            // behind animated characters. histMean / histFc stay at 0 — the
            // FC blend below uses current sample only this frame, accepting
            // the single-sample edge sparkle in exchange for zero trail.
        }

    } else if (primaryInstanceId != 0u) {
        // ── This pixel moved (or camera moved): bilinear 4-tap reproject
        //
        // Two prevU/prevV sources:
        //   (a) hybrid: read the raster gbuffer's per-pixel motion vector
        //       directly. Sub-pixel exact for moving objects (vs reverse-
        //       projection through prev camera basis, which is sensitive
        //       to float precision on long-throw cameras), no motionMat
        //       lookup needed, and works on InstancedMesh sub-instances
        //       without per-instance pre-baking.
        //   (b) legacy: reverse-project this frame's primaryWorldPos through
        //       motionMat (per-instance prev*inv(curr)) and the prev camera
        //       basis. The original path; kept for non-hybrid runs.
        float prevU = 0.0, prevV = 0.0;
        bool  reprojValid = false;

        // Reverse-project current world hit through the per-instance motion
        // matrix and prev camera basis. Used unconditionally now:
        //   • Legacy path: provides prevU/prevV for the bilinear reproject.
        //   • Hybrid path: prevU/prevV come from the gbuffer motion vector,
        //     but prevWS/prevZ are still needed to gate skinned/displaced
        //     meshes — motionMat is identity for those (the rigid worldMatrix
        //     doesn't change when only bones rotate), so the gate flags any
        //     prev-gbuf position that drifted from currWS by more than the
        //     tightened tolerance below as deformed-and-stale.
        const mat4 motion = motionMat[primaryInstanceId - 1u];
        // 2026-05-13: reproject uses chit's per-vertex prev-world position
        // instead of motionMat·primaryWorldPos directly. For static/rigid
        // meshes primaryPrevWorldPos == primaryWorldPos (chit's prev-vertex
        // interpolation falls through to the same buffer), so the result
        // identical to the old motionMat·primaryWorldPos formula. For
        // skinned/displaced meshes primaryPrevWorldPos captures the previous
        // frame's deformed surface point in CURRENT-frame world space —
        // applying motionMat then takes it to PREV-frame world space, which
        // is what the prev-camera-basis projection below expects.
        const vec3 prevWS  = (motion * vec4(primaryPrevWorldPos, 1.0)).xyz;
        const vec3 toPoint = prevWS - pcam.prevCamPosX.xyz;
        const float prevZ  = dot(toPoint, pcam.prevCamFwdY.xyz);

        if (hybridOn) {
            const vec2 uv       = (vec2(gl_LaunchIDEXT.xy) + 0.5) / vec2(sz);
            const vec2 motionGL = texture(gbufMotionTex, uv).rg;
            // gbuffer motion vector is in GL-convention NDC (Y up).
            const vec2 currNDC = vec2(uv.x * 2.0 - 1.0, -(uv.y * 2.0 - 1.0));
            const vec2 prevNDC = currNDC + motionGL;
            prevU = (prevNDC.x * 0.5 + 0.5) * float(sz.x) - 0.5;
            prevV = (0.5 - prevNDC.y * 0.5) * float(sz.y) - 0.5;
            // Jitter-delta correction: the surface this pixel rasterized to
            // sat at the JITTERED pixel position last frame too, but with a
            // different Halton sample. motion vec is computed from unjittered
            // projections (vCurrClipUnjit / vPrevClip in gbuffer.vert), so
            // prevU/V here lands on the unjittered prev pixel — half a pixel
            // off from where prev raygen actually wrote into prevAccumImage.
            // Add (prev_jitter - curr_jitter) in pixel space to land on the
            // prev rasterized pixel exactly. cam.jitter is in clip space
            // ([-1,1] NDC), so multiply by size/2. Y axis: clip and GL-NDC
            // agree on sign because the projection's m12 (clip Y) is what
            // shifts; the gl_Position Y flip happens after.
            const vec2 jDelta = (cam.jitter.zw - cam.jitter.xy) * 0.5 * vec2(sz);
            prevU += jDelta.x;
            prevV -= jDelta.y;
            reprojValid = true;
        } else if (prevZ > 0.001) {
            const float ndcX = dot(toPoint, pcam.prevCamRgt.xyz) * pcam.prevCamPosX.w / prevZ;
            const float ndcY = dot(toPoint, pcam.prevCamUp.xyz)  * pcam.prevCamFwdY.w / prevZ;
            // Pixel-space reprojection. The forward camera ray puts
            // pixel (i,j)'s CENTER at NDC = ((i+0.5)/sx*2-1, ...).
            // Reversing back gives prevU = i + 0.5; bilinear expects
            // integer coords AT pixel centers, so we subtract 0.5.
            // Without this shift, an unmoved world point produces
            // fx=fy=0.5 (all four taps = 0.25 weight), smearing
            // content half-a-pixel down-and-right.
            prevU = (ndcX * 0.5 + 0.5) * float(sz.x) - 0.5;
            prevV = (0.5 - ndcY * 0.5) * float(sz.y) - 0.5;
            reprojValid = true;
        }

        if (reprojValid) {
            const ivec2 b = ivec2(int(floor(prevU)), int(floor(prevV)));
            if (b.x >= 0 && b.x + 1 < sz.x && b.y >= 0 && b.y + 1 < sz.y) {
                // Bilinear weights
                const float fx  = prevU - float(b.x);
                const float fy  = prevV - float(b.y);
                const float w00 = (1.0 - fx) * (1.0 - fy);
                const float w10 =        fx  * (1.0 - fy);
                const float w01 = (1.0 - fx) *        fy;
                const float w11 =        fx  *        fy;

                // Zero weight for any tap whose prev mesh-ID doesn't match OR
                // whose stored prev-frame world position is too far from the
                // expected prevWS for this surface point. Mesh-ID alone is
                // insufficient under sideways camera translation: a wall
                // extending from near to far is one mesh, and a bilinear
                // neighbor pixel that landed on the far end while the curr
                // pixel is the near end would otherwise be accepted, ghosting
                // old far-end radiance into the near-end accumulator.
                //
                // The depth tolerance scales with prev-camera-space Z so the
                // pass band is a fixed angular cone rather than a fixed world
                // distance. 5%·prevZ comfortably covers same-surface
                // sub-pixel offsets (2-pixel bilinear span × per-pixel angle
                // ≈ 0.002·prevZ) while rejecting depth jumps that produce
                // sideways-motion smear.
                const vec4  g00v = imageLoad(prevGbufImage, b              );
                const vec4  g10v = imageLoad(prevGbufImage, b + ivec2(1,0));
                const vec4  g01v = imageLoad(prevGbufImage, b + ivec2(0,1));
                const vec4  g11v = imageLoad(prevGbufImage, b + ivec2(1,1));
                // Depth-tolerance gate: only meaningful in the legacy reverse-
                // projection path where prevWS / prevZ map currWS into prev-
                // camera space directly. Hybrid skips it — the gbuffer motion
                // vector is sub-pixel exact for the surface this pixel belongs
                // to, and on glancing / curved skinned surfaces the prev-gbuf
                // at bilinear neighbours legitimately differs from prevWS by
                // pixel-sized world distances; a tight gate would reject
                // them and add noise. Skin lingering on-mesh is acceptable
                // (the user looks at the *mesh*, not its silhouette trail);
                // the wispy sky trail surrounding moving skinned meshes is
                // handled in the self-tap branch above by mesh-ID validation.
                const bool depthGate = !hybridOn;
                // 2026-05-13: tightened from 5% to 1%·prevZ. Skinned-mesh
                // animations have motionMat=identity (only worldMatrix tracked,
                // not bone matrices), so prev-gbuf at the surface-reprojected
                // pixel records the OLD pose's hit position. 5% was loose
                // enough that typical per-frame bone deltas slipped through,
                // accepting prev content → partial blend of old+new pose →
                // visible blur on animated characters. 1% rejects deltas of
                // ~1%·prev surface depth (typical bone motion), cold-starts
                // the affected pixels. Still well above sub-pixel rigid
                // motion (~0.2%·prevZ), so rigid reproject is unaffected.
                const float dEps2 = depthGate ? (0.01 * prevZ) * (0.01 * prevZ) : 0.0;
                const vec3 d00 = depthGate ? (g00v.xyz - prevWS) : vec3(0.0);
                const vec3 d10 = depthGate ? (g10v.xyz - prevWS) : vec3(0.0);
                const vec3 d01 = depthGate ? (g01v.xyz - prevWS) : vec3(0.0);
                const vec3 d11 = depthGate ? (g11v.xyz - prevWS) : vec3(0.0);
                // All-or-nothing reproject: every bilinear tap must match
                // the same mesh AND pass the depth gate, else the entire
                // 2×2 footprint is rejected and the pixel cold-starts.
                // Per-tap acceptance previously let some taps survive at
                // silhouette boundaries (asphalt/cone): rejected taps had
                // weight 0 but accepted taps still carried content → demod
                // saw blended radiance ÷ current-frame albedo as a wrong-
                // mesh outlier → atrous preserved it → visible ghost. With
                // strict all-or-nothing, silhouette pixels disocclude
                // cleanly (FC=0 there) and the demod stays mathematically
                // consistent (radiance and albedo both fresh-current).
                //
                // Tap-match relaxation: accept on same-instance-id OR
                // same-material-asset-id. Two Mesh objects sharing one
                // Material C++ object (tiled wall, brick row, fence
                // sections) have different instance ids but identical
                // materialAssetIdx → bilinear sees the seam pixels as one
                // logical surface, reproject succeeds, no cold-start
                // sparkle along the join. The depth gate stays in place
                // and still rejects across genuine geometric breaks
                // (corner where two same-material planes meet at angle).
                const uint mesh00 = uint(g00v.w);
                const uint mesh10 = uint(g10v.w);
                const uint mesh01 = uint(g01v.w);
                const uint mesh11 = uint(g11v.w);
                const bool mat00 = (mesh00 != 0u) && (mats[mesh00 - 1u].materialAssetIdx == primaryMatAssetIdx);
                const bool mat10 = (mesh10 != 0u) && (mats[mesh10 - 1u].materialAssetIdx == primaryMatAssetIdx);
                const bool mat01 = (mesh01 != 0u) && (mats[mesh01 - 1u].materialAssetIdx == primaryMatAssetIdx);
                const bool mat11 = (mesh11 != 0u) && (mats[mesh11 - 1u].materialAssetIdx == primaryMatAssetIdx);
                const bool m00 = (mesh00 == primaryInstanceId || mat00) && (!depthGate || dot(d00,d00) < dEps2);
                const bool m10 = (mesh10 == primaryInstanceId || mat10) && (!depthGate || dot(d10,d10) < dEps2);
                const bool m01 = (mesh01 == primaryInstanceId || mat01) && (!depthGate || dot(d01,d01) < dEps2);
                const bool m11 = (mesh11 == primaryInstanceId || mat11) && (!depthGate || dot(d11,d11) < dEps2);
                const bool allMatch = m00 && m10 && m01 && m11;
                const float v00 = allMatch ? w00 : 0.0;
                const float v10 = allMatch ? w10 : 0.0;
                const float v01 = allMatch ? w01 : 0.0;
                const float v11 = allMatch ? w11 : 0.0;
                const float wSum = v00 + v10 + v01 + v11;

                if (wSum > 1e-4) {
                    const vec4 a00 = imageLoad(prevAccumImage, b              );
                    const vec4 a10 = imageLoad(prevAccumImage, b + ivec2(1,0));
                    const vec4 a01 = imageLoad(prevAccumImage, b + ivec2(0,1));
                    const vec4 a11 = imageLoad(prevAccumImage, b + ivec2(1,1));
                    const vec3 bMean = (a00.rgb*v00 + a10.rgb*v10 + a01.rgb*v01 + a11.rgb*v11) / wSum;
                    const float bFc  = (a00.w  *v00 + a10.w  *v10 + a01.w  *v01 + a11.w  *v11) / wSum;
                    // Moments use the same bilinear weights so the per-pixel
                    // variance estimate follows the same physical surface
                    // point as the mean. Without matching the taps, M2 and M1
                    // would describe slightly different surface regions and
                    // produce stale-variance ghost trails behind moving
                    // objects.
                    const float m00 = imageLoad(prevMomentsImage, b              ).r;
                    const float m10 = imageLoad(prevMomentsImage, b + ivec2(1,0)).r;
                    const float m01 = imageLoad(prevMomentsImage, b + ivec2(0,1)).r;
                    const float m11 = imageLoad(prevMomentsImage, b + ivec2(1,1)).r;
                    const float bLum2 = (m00*v00 + m10*v10 + m01*v01 + m11*v11) / wSum;
                    // Same bilinear blend for prev albedo, with the same
                    // mesh-ID + depth-validated tap weights. Keeps the
                    // demod albedo channel in lockstep with the radiance
                    // channel (any sub-pixel reproject error blurs BOTH
                    // signals the same way → demod division remains
                    // mathematically consistent → no ghost smear).
                    const vec4 pal00 = imageLoad(prevPrimaryAlbedoImage, b              );
                    const vec4 pal10 = imageLoad(prevPrimaryAlbedoImage, b + ivec2(1,0));
                    const vec4 pal01 = imageLoad(prevPrimaryAlbedoImage, b + ivec2(0,1));
                    const vec4 pal11 = imageLoad(prevPrimaryAlbedoImage, b + ivec2(1,1));
                    const vec3 bAlbedoRGB = (pal00.rgb*v00 + pal10.rgb*v10
                                           + pal01.rgb*v01 + pal11.rgb*v11) / wSum;
                    const float bAlbedoA  = (pal00.a*v00 + pal10.a*v10
                                           + pal01.a*v01 + pal11.a*v11) / wSum;
                    if (!any(isnan(bMean)) && !any(isinf(bMean))) {
                        histMean = bMean;
                        if (!isnan(bLum2) && !isinf(bLum2)) histLum2 = bLum2;
                        histAlbedoRGB = bAlbedoRGB;
                        histAlbedoA   = bAlbedoA;
                        // Roughness-aware FC cap + floor.
                        //
                        // Cap (upper): split into movingCap (mesh self-moved) vs
                        // staticCap (only camera moved). Static-mesh diffuse
                        // shading barely changes with viewpoint, so cam-only
                        // motion deserves a much higher cap (mirrors WGPU PT).
                        //
                        // Floor (lower): without a floor the halving every motion
                        // frame drives FC to ~2 in continuous motion (geom-series
                        // equilibrium of x = x/2 + 1). The cap only helps the
                        // FIRST frame after a static→moving transition. A small
                        // floor makes continuous-motion FC settle at floor+1
                        // instead of 2 — that's the lever that actually cuts
                        // moving-pixel noise and stops the bilinear-ringing shake
                        // (per-sample variance shows up amplified when only a
                        // handful of samples back the running mean).
                        //
                        // Floor is kept small so the post-motion ghost trail
                        // decays in roughly floor·9 frames (~0.6s @ 60fps for
                        // rough=4) — perceptually invisible on diffuse surfaces
                        // where stale and fresh samples converge to the same
                        // mean anyway, and short enough on glossy that we don't
                        // smear specular highlights past where they belong.
                        const float roughT = smoothstep(0.15, 0.7, primaryRoughness);
                        // Caps + floors are tuned for the default spp=4. Caps
                        // raised ~2× from the spp=1 values so high-spp budget
                        // sticks at moving pixels; with FC advancing by spp/frame,
                        // a cap of 128 still settles in ~32 frames (~½ s @60 fps).
                        // Floors raised so the continuous-motion equilibrium
                        // (x = x/2 + spp = 2·spp) doesn't collapse below the
                        // intended sample count on smooth surfaces.
                        float capUp  = primaryMoved
                                ? mix(16.0, 128.0, roughT)
                                : mix(16.0,  96.0, roughT);
                        float capLo  = primaryMoved
                                ? mix(4.0,  8.0, roughT)
                                : mix(4.0, 12.0, roughT);
                        // Glass-specific floor / cap. Glass uses a stochastic
                        // reflect-vs-refract branch (chit ~line 894). At normal
                        // incidence Schlick F ≈ 0.04, so ~4% of samples are
                        // achromatic reflections; the other ~96% are tinted
                        // refractions. With the smooth-surface floor of 4, the
                        // running mean has only 5-6 samples backing it under
                        // continuous camera motion — a single reflect outlier
                        // landing in that handful shifts the chromatic balance
                        // ~20% toward white, producing visible tint loss /
                        // flicker on tinted glass spheres while the camera moves.
                        // Refracted content reprojects with parallax (anchored
                        // on the glass surface), so keeping more history does
                        // NOT cause mirror-style ghosting. Bump floor + cap so
                        // continuous-motion FC settles around 24-32, dropping
                        // tint variance ~3-4×.

                        // ── View-dependent radiance: spec/metal smear suppression ──
                        // The roughness-aware caps above were tuned for variance
                        // reduction (rough = wide lobe = high per-sample variance =
                        // needs more history; smooth = narrow lobe = low variance =
                        // less history needed). But they don't account for the
                        // fact that smooth surfaces also have HIGHLY view-dependent
                        // radiance: the BRDF lobe rotates with view direction, so
                        // each frame samples DIFFERENT env/scene content at the
                        // same surface point. Surface-anchored reprojection blends
                        // those values as if they were samples of the same
                        // integrand — they aren't — so the running mean lags
                        // behind the true new-view integrand, manifesting as
                        // visible smear/ghost trails on mirrors, chrome, glossy
                        // paint when the camera translates. Worst close to the
                        // surface where view-direction delta per frame is largest.
                        //
                        // Fix: on motion frames, drop the cap aggressively for
                        // view-dependent (metal OR low-roughness) primary surfaces
                        // so the mean re-locks to the new view's integrand in a
                        // few frames instead of dragging the old one along.
                        // Glass is excluded — refracted content reprojects with
                        // parallax (anchored on the glass surface), so keeping
                        // history does NOT cause mirror-style ghosting (per the
                        // tint-stability block above).
                        // View-dep weight comes directly from chit's
                        // Fresnel-weighted spec-vs-diff fraction (computed
                        // at the actual surface with full material info).
                        // Replaces the old roughness/metalness heuristic
                        // — that heuristic completely missed dark surfaces
                        // (wet asphalt, dark paint, dim plastic) where
                        // the dim diffuse component can't compete with
                        // Fresnel spec → most of their outgoing radiance
                        // IS view-dependent even at moderate roughness.
                        // 2026-05-14 Vehicle demo: cones at low NdotV
                        // were leaving blue sky-reflection trails because
                        // the heuristic said roughness=0.3 → viewDepT=0.5,
                        // but actual spec fraction was ~0.85 (low albedo
                        // × high Fresnel). Direct signal is precise.
                        const bool isGlassP = primaryTransmission > 0.05;
                        const float viewDepT = isGlassP ? 0.0 : primarySpecFrac;
                        // ── Emissive smear suppression ──
                        // Emissive primary surfaces have view-INDEPENDENT radiance
                        // (so the view-dep factor above doesn't catch them), but
                        // their extreme per-pixel luminance — typically 50-500×
                        // scene base, or higher with HDR emissives — amplifies any
                        // sub-pixel reprojection error from the 4-tap bilinear-
                        // style blend into a visible smear trail under camera
                        // motion. Diffuse walls have the same per-frame error
                        // mechanism but their BG/FG values are similar so it's
                        // invisible; emissives turn it into a comet tail.
                        // Same fix family: detect bright primary radiance, force
                        // fast FC decay so the compound blur can't accumulate.
                        // Soft threshold 10..30 lum picks up typical emissives
                        // (intensity * color around 1-50 scene-linear pre-clamp)
                        // without false-positives on sunlit diffuse surfaces
                        // (~1-3 lum scene-linear under typical exposure).
                        const float primaryLum = dot(radianceSum,
                                vec3(0.2126, 0.7152, 0.0722)) / float(effSpp);
                        const float emissiveT = clamp((primaryLum - 10.0) / 20.0, 0.0, 1.0);
                        const float decayT = max(viewDepT, emissiveT);
                        // FC requirement from the view-dep math: to flush a
                        // fraction X of view-dep content per frame, current
                        // weight must be ≥ X, i.e. FC ≤ 1/X. For specFrac=0.6
                        // (wet asphalt, dark plastic at mid view angle):
                        // cap=1.67. For specFrac=0.3 (cones at normal):
                        // cap=3.3. For pure diffuse (specFrac=0.05): cap=20.
                        // FC requirement from view-dep math: to flush a
                        // fraction X of view-dep content per frame, current
                        // weight must be ≥ X, i.e. FC ≤ 1/X. For specFrac=0.6
                        // (wet asphalt): cap=1.67. For specFrac=0.3 (cones at
                        // normal): cap=3.3. For pure diffuse (specFrac=0.05):
                        // cap=20.
                        if (primaryMoved && decayT > 0.05) {
                            const float viewDepFC = 1.0 / max(decayT, 0.05);
                            capUp = min(capUp, viewDepFC);
                            capLo = min(capLo, max(viewDepFC, 1.0));
                        }

                        // Velocity-clamped FC cap. Bilinear reproject under
                        // continuous sub-pixel motion compounds drift each
                        // frame — over N frames at v px/frame motion, the
                        // accumulator's effective footprint blurs by ~N*v
                        // sub-pixels in the texture-sample sense. To keep
                        // cumulative blur bounded (≤ ~10 px-frames of drift),
                        // cap FC at 10 / motionPx. At motionPx < 0.5 (sub-
                        // pixel motion, essentially self-tap), cap is loose
                        // (FC = 20+); at motionPx = 5+ (fast translation),
                        // cap collapses to FC ≤ 2 — keeps moving textured
                        // surfaces from accumulating drift into severe
                        // smearing (cube text smearing under sideways
                        // camera translation was the symptom).
                        const vec2 motionVec = vec2(prevU - float(px.x),
                                                    prevV - float(px.y));
                        const float motionPx = length(motionVec);
                        const float velocityFc = 10.0 / max(motionPx, 0.5);
                        capUp = min(capUp, velocityFc);
                        capLo = min(capLo, max(velocityFc * 0.5, 1.0));

                        histFc = clamp(bFc * 0.5, capLo, capUp);
                    }
                }
            }
        }
    }
    // Sky pixel with camMoved: falls through both branches → histFc=0 cold-start.
    // Sky pixel with only foreign-mesh motion: self-tapped above (no change).

    // radianceSum is the SUM of `effSpp` per-sample radiance values (= spp
    // for interior pixels, spp + EDGE_MSAA_EXTRA at detected silhouettes).
    // Each sample counts as one effective sample in the running mean:
    // blend weight = effSpp, FC advances by effSpp. Silhouette pixels
    // accumulate FC slightly faster, which is correct — they're genuinely
    // less noisy per frame, so atrous's σ_lum sees lower variance there too.
    const float sppF  = float(effSpp);
    const vec3  mean  = (histMean * histFc + radianceSum) / (histFc + sppF);
    const float newFc = min(histFc + sppF, 4096.0);
    // M2 update: same FC weight as mean. Equivalent to:
    //   M2 = (Σ_history lum² + Σ_this_frame lum²) / total_samples.
    // Subnormal-flush safe: lum² stays well above subnormal range for any
    // realistic radiance value (~0.01 → 1e-4 stored as plain float).
    const float lum2Mean = (histLum2 * histFc + lum2Sum) / (histFc + sppF);
    imageStore(accumImage, px, vec4(mean, newFc));
    imageStore(momentsImage, px, vec4(lum2Mean, 0.0, 0.0, 0.0));
    imageStore(gbufImage, px, vec4(primaryWorldPos, float(primaryInstanceId)));

    // Temporal albedo blend. chit fills payload.primaryAlbedo per primary
    // ray (.a=1 for demod-valid surfaces, otherwise vec4(0)). Blend with
    // the reprojected prev albedo using histFc as the weight so the
    // albedo accumulator tracks the SAME temporal blend as the radiance
    // accumulator — keeps demod division consistent.
    vec3  finalAlbedoRGB;
    float finalAlbedoA;
    if (primaryAlbedoSnapshot.a > 0.5 && histAlbedoA > 0.5) {
        // Cap albedo's effective FC at 8 (vs radiance's up-to-60 default
        // cap). The radiance accumulator benefits from 60-frame averaging
        // for noise reduction, but the SAME 60-frame window applied to
        // albedo accumulates sub-pixel reproject drift on textured
        // surfaces into severe smearing (cube text becomes illegible
        // under sideways camera translation). 8 frames is enough to
        // suppress chit's per-frame UV jitter (FC=8 → ~12% per-frame
        // weight) while keeping the bilinear reproject's drift contained.
        const float albedoFc = min(histFc, 8.0);
        finalAlbedoRGB = (histAlbedoRGB * albedoFc + primaryAlbedoSnapshot.rgb)
                       / (albedoFc + 1.0);
        finalAlbedoA   = 1.0;
    } else if (primaryAlbedoSnapshot.a > 0.5) {
        // Curr valid, no history: use curr only.
        finalAlbedoRGB = primaryAlbedoSnapshot.rgb;
        finalAlbedoA   = 1.0;
    } else {
        // Curr invalid: pixel is demod-disabled this frame regardless of
        // history. Write zero so atrous skips demod here.
        finalAlbedoRGB = vec3(0.0);
        finalAlbedoA   = 0.0;
    }
    imageStore(primaryAlbedoImage, px, vec4(finalAlbedoRGB, finalAlbedoA));
    // Snapshot: just this-frame's chit value, no temporal blend. Atrous
    // reads at center for the re-mod step so texture detail isn't dimmed
    // by the temporal-blend lag under motion.
    imageStore(primaryAlbedoSnapshotImage, px, primaryAlbedoSnapshot);
    // Tonemap + sRGB encode + outImage write moved to denoise.comp so the
    // spatial filter can run on linear HDR before display encode.
}
