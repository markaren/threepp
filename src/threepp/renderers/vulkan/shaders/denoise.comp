#version 460

// PT "resolve" stage (formerly the finalize tonemap stage).
//
// Reads the raw temporally-accumulated radiance (accumImage) and the
// multi-pass à-trous output (filteredArray[0]), mixes them per-pixel by the
// filter weight the à-trous stage wrote into filtered.a, and writes the
// result as LINEAR HDR to outImage (rgba16f).
//
// Tone mapping + sRGB encode + bloom compositing now happen downstream in
// composite.comp (BloomPass), so bloom can be added in linear HDR *before*
// the tone-map curve (correct, AAA-style glow) instead of on already-
// compressed LDR. When bloom is disabled the composite stage performs the
// exact tone-map + sRGB + solid-bg bypass this stage used to do, so the
// final image is identical to the pre-split behaviour.
//
// When denoiseEnabled == 0 the filtered read is skipped — output is the raw
// accumulated radiance (still linear HDR; composite tonemaps it).
//
// Two à-trous passes (denoise_atrous.comp) run before this stage; the final
// pass writes filteredArray[0], whose .a carries the per-pixel filter weight.

layout(local_size_x = 8, local_size_y = 8, local_size_z = 1) in;

// rgba16f: linear HDR scene colour consumed by the bloom down-sample + the
// composite tone-map pass. (Was rgba8 tonemapped output before the split.)
layout(set = 0, binding = 1, rgba16f) uniform writeonly image2D outImage;
layout(set = 0, binding = 7,  rgba32f) uniform readonly image2D accumImage;
layout(set = 0, binding = 12, rgba32f) uniform readonly image2D gbufImage;
layout(set = 0, binding = 20, rgba32f) uniform readonly image2D filteredArray[2];

layout(push_constant) uniform Pc {
    uint toneMapping;     // unused here — composite.comp owns tone mapping
    uint exposureBits;    // unused here — kept for ABI parity with the
    uint denoiseEnabled;  // Denoiser::recordDispatch finalize push (4×u32).
    uint bgIsSolidColor;  // unused here — composite.comp owns the bg bypass.
} pc;

void main() {
    const ivec2 size = imageSize(accumImage);
    const ivec2 px   = ivec2(gl_GlobalInvocationID.xy);
    if (px.x >= size.x || px.y >= size.y) return;

    const vec4 raw = imageLoad(accumImage, px);  // xyz = mean radiance, w = FC
    const vec4 g   = imageLoad(gbufImage,  px);  // .w = instanceId+1 (0 = sky)

    vec3 color = raw.rgb;

    // Sky pixels bypass the filtered mix — env is already temporally smooth.
    if (pc.denoiseEnabled != 0u && g.w > 0.5) {
        // The à-trous stage wrote a per-pixel filter-mix weight into
        // filtered.a: high where the pixel is still noisy (fresh disocclusion
        // OR high residual variance), → 0 where it has settled clean. Mixing
        // by it keeps the spatial filter ON wherever it helps and OFF on
        // converged pixels (so texture/detail stays crisp).
        const vec4  filtered = imageLoad(filteredArray[0], px);
        const float wFilt    = filtered.a;
        if (wFilt > 0.001) {
            color = mix(raw.rgb, filtered.rgb, wFilt);
        }
    }

    // Linear HDR out — composite.comp applies tone map + sRGB (+ bloom).
    imageStore(outImage, px, vec4(color, 1.0));
}
